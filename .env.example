DB_HOST=db
DB_PORT=3306
DB_NAME=shulkertech
DB_USER=shulkertech
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme

# TLS for remote database connections (leave unset for same-host/Docker deployments).
# DB_SSL_CA is required to enable TLS; CERT and KEY are only needed for mutual TLS.
# Set DB_SSL_VERIFY=false to accept self-signed certificates.
#DB_SSL_CA=/etc/ssl/certs/ca.pem
#DB_SSL_CERT=/etc/ssl/certs/client-cert.pem
#DB_SSL_KEY=/etc/ssl/certs/client-key.pem
#DB_SSL_VERIFY=true

# Base URLs for each subdomain — used to build nav links.
# In local dev both point to localhost. In production use real subdomains.
HOME_URL=https://localhost
WIKI_URL=https://wiki.localhost
ADMIN_URL=https://admin.localhost

# Discord server widget ID
DISCORD_SERVER_ID=

# Token required to access the /setup first-run page
ADMIN_SETUP_TOKEN=changeme-set-something-secret

# Directory for file-based server status cache (must be writable by www-data)
CACHE_DIR=/var/www/cache

# Share sessions across all subdomains. Use a leading dot.
# Local dev:   SESSION_DOMAIN=.localhost
# Production:  SESSION_DOMAIN=.yourdomain.com
SESSION_DOMAIN=.localhost

# Override subdomain detection for local dev (e.g. "admin", "wiki"). Leave unset in production.
SUBDOMAIN_OVERRIDE=
