DB_NAME=shulkertech
DB_USER=shulkertech
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme

# An optional link to a bluemap server to act as your hero image
BLUEMAP_URL=http://localhost:8100

# Base URLs for each subdomain — used to build nav links.
# In local dev both point to localhost. In production use real subdomains.
HOME_URL=http://localhost:8080
WIKI_URL=http://wiki.localhost:8080

# Override subdomain detection for local dev (e.g. "wiki"). Leave unset in production.
SUBDOMAIN_OVERRIDE=
