# ── Required ──────────────────────────────────────────────────────────────────
APP_KEY=                          # Generate with: php artisan key:generate
APP_URL=https://yourdomain.com
APP_DOMAIN=yourdomain.com

DB_NAME=shulkertech
DB_USER=shulkertech
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme

ADMIN_SETUP_TOKEN=changeme        # Secret token for the /setup first-run wizard


# ── Optional: features ────────────────────────────────────────────────────────
# DISCORD_SERVER_ID=              # Enables the Discord widget on the home page

# ── Optional: TLS for remote database (not needed for Docker deployments) ─────
# DB_SSL_CA=/etc/ssl/certs/ca.pem
# DB_SSL_CERT=/etc/ssl/certs/client-cert.pem
# DB_SSL_KEY=/etc/ssl/certs/client-key.pem
# DB_SSL_VERIFY=true
