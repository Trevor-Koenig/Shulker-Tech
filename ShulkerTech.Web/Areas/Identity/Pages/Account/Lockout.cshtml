@page
@model LockoutModel
@{
    ViewData["Title"] = "Locked Out";
}

<div class="min-h-screen flex items-center justify-center px-4 py-16"
     style="background: radial-gradient(ellipse at 50% 0%, color-mix(in oklab, var(--color-rune) 20%, transparent), var(--color-void) 70%);">

    <div class="w-full max-w-sm text-center">
        <div class="mb-8">
            <p class="text-xs tracking-widest mb-3" style="font-family: var(--font-mono); color: var(--color-rune);">&#9670; SHULKER TECH &#9670;</p>
            <h1 style="font-family: var(--font-display); font-size: 1.75rem; font-weight: 900; letter-spacing: 0.1em; color: var(--color-rune);">
                ACCESS DENIED
            </h1>
        </div>

        <div class="panel p-8 flex flex-col gap-4">
            <div style="font-size: 3rem; color: var(--color-rune);">&#128274;</div>
            <p class="text-sm" style="color: var(--color-muted); font-family: var(--font-mono); line-height: 1.6;">
                This terminal has been locked due to too many failed authentication attempts.
            </p>
            <p class="text-xs" style="color: var(--color-muted); font-family: var(--font-mono);">
                Please try again later.
            </p>
            <div class="pt-2" style="border-top: 1px solid color-mix(in oklab, var(--color-rune) 15%, transparent);">
                <a asp-page="./Login"
                   class="text-xs" style="color: var(--color-accent); font-family: var(--font-mono); text-decoration: none;"
                   onmouseover="this.style.textDecoration='underline';" onmouseout="this.style.textDecoration='none';">
                    &larr; Return to sign in
                </a>
            </div>
        </div>
    </div>
</div>
