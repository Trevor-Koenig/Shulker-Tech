@page
@model LoginWithRecoveryCodeModel
@{
    ViewData["Title"] = "Recovery Code Sign In";
}

<div class="min-h-screen flex items-center justify-center px-4 py-16"
     style="background: radial-gradient(ellipse at 50% 0%, color-mix(in oklab, var(--color-nebula) 60%, transparent), var(--color-void) 70%);">

    <div class="w-full max-w-sm">

        <div class="text-center mb-8">
            <p class="text-xs tracking-widest mb-3" style="font-family: var(--font-mono); color: var(--color-accent);">&#9670; SHULKER TECH &#9670;</p>
            <h1 style="font-family: var(--font-display); font-size: 1.75rem; font-weight: 900; letter-spacing: 0.1em; color: var(--color-crystal);">
                RECOVERY CODE
            </h1>
            <p class="text-xs mt-2" style="font-family: var(--font-mono); color: var(--color-muted);">
                Enter one of your saved recovery codes.
            </p>
        </div>

        <div class="panel p-8 flex flex-col gap-5">

            <div asp-validation-summary="ModelOnly" class="text-xs p-3 rounded" role="alert"
                 style="color: var(--color-rune); background: color-mix(in oklab, var(--color-rune) 10%, transparent); border: 1px solid color-mix(in oklab, var(--color-rune) 30%, transparent); font-family: var(--font-mono); display: @(ViewData.ModelState.IsValid ? "none" : "block");">
            </div>

            <form method="post" class="flex flex-col gap-4">

                <div class="flex flex-col gap-1">
                    <label asp-for="Input.RecoveryCode" class="text-xs tracking-wider"
                           style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">RECOVERY CODE</label>
                    <input asp-for="Input.RecoveryCode" autocomplete="off"
                           placeholder="xxxx-xxxx"
                           class="w-full px-3 py-3 rounded text-center tracking-widest"
                           style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent); color: var(--color-crystal); outline: none; font-family: var(--font-mono);"
                           onfocus="this.style.borderColor='var(--color-accent)'; this.style.boxShadow='0 0 12px color-mix(in oklab, var(--color-accent) 25%, transparent)';"
                           onblur="this.style.borderColor='color-mix(in oklab, var(--color-accent) 30%, transparent)'; this.style.boxShadow='none';" />
                    <span asp-validation-for="Input.RecoveryCode" class="text-xs" style="color: var(--color-rune); font-family: var(--font-mono);"></span>
                </div>

                <button type="submit" class="btn-primary w-full py-3">
                    SIGN IN
                </button>

            </form>

            <div class="text-center pt-2" style="border-top: 1px solid color-mix(in oklab, var(--color-accent) 10%, transparent);">
                <a asp-page="./LoginWith2fa" asp-route-returnUrl="@Model.ReturnUrl"
                   class="text-xs" style="color: var(--color-muted); font-family: var(--font-mono); text-decoration: none;"
                   onmouseover="this.style.textDecoration='underline';" onmouseout="this.style.textDecoration='none';">
                    &larr; Use authenticator code instead
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
