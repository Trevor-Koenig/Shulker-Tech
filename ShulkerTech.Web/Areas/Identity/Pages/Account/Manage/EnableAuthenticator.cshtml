@page
@model EnableAuthenticatorModel
@{
    ViewData["Title"] = "Set Up Authenticator";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<div class="max-w-5xl mx-auto px-4 py-12">
    <div class="flex flex-col sm:flex-row gap-6">

        <aside class="sm:w-44 flex-shrink-0 panel p-4">
            <partial name="_ManageNav" />
        </aside>

        <div class="flex-1 panel p-8 flex flex-col gap-6">

            <h2 style="font-family: var(--font-display); font-size: 1rem; font-weight: 700; letter-spacing: 0.1em; color: var(--color-crystal);">SET UP AUTHENTICATOR APP</h2>

            <partial name="_StatusMessage" for="StatusMessage" />

            @* Step 1 *@
            <div class="flex flex-col gap-3">
                <p class="text-xs" style="font-family: var(--font-display); color: var(--color-accent); letter-spacing: 0.1em;">STEP 1 — INSTALL AN APP</p>
                <p class="text-sm" style="color: var(--color-muted); font-family: var(--font-mono); line-height: 1.6;">
                    Download an authenticator app such as Google Authenticator, Authy, or Microsoft Authenticator on your phone.
                </p>
            </div>

            <div style="border-top: 1px solid color-mix(in oklab, var(--color-accent) 10%, transparent);"></div>

            @* Step 2 — Key *@
            <div class="flex flex-col gap-3">
                <p class="text-xs" style="font-family: var(--font-display); color: var(--color-accent); letter-spacing: 0.1em;">STEP 2 — ADD YOUR ACCOUNT</p>
                <p class="text-sm" style="color: var(--color-muted); font-family: var(--font-mono); line-height: 1.6;">
                    In your authenticator app, choose to add a new account manually and enter the key below, or scan the QR code if your app supports it.
                </p>

                <div class="flex flex-col gap-2">
                    <p class="text-xs" style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.06em;">ACCOUNT KEY</p>
                    <div class="flex items-center gap-3">
                        <code id="shared-key"
                              class="flex-1 px-4 py-3 rounded text-sm tracking-widest select-all"
                              style="font-family: var(--font-mono); color: var(--color-arcane);
                                     background: color-mix(in oklab, var(--color-arcane) 8%, var(--color-void));
                                     border: 1px solid color-mix(in oklab, var(--color-arcane) 30%, transparent);
                                     letter-spacing: 0.15em; word-break: break-all;">@Model.SharedKey</code>
                        <button type="button" onclick="copyKey()" title="Copy key"
                                class="px-3 py-3 rounded text-xs flex-shrink-0"
                                style="font-family: var(--font-display); color: var(--color-arcane);
                                       border: 1px solid color-mix(in oklab, var(--color-arcane) 30%, transparent);
                                       background: color-mix(in oklab, var(--color-arcane) 8%, transparent);
                                       transition: background 150ms, color 150ms; cursor: pointer;">
                            COPY
                        </button>
                    </div>
                </div>

                @* QR code *@
                <div class="flex flex-col gap-2 mt-1">
                    <p class="text-xs" style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.06em;">QR CODE</p>
                    <div id="qr-code" style="display: inline-block; align-self: flex-start; padding: 0.75rem; background: #fff; border-radius: 0.35rem; line-height: 0;"></div>
                    <p class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted);">
                        Scan this with your authenticator app, or enter the key above manually.
                    </p>
                </div>
            </div>

            <div style="border-top: 1px solid color-mix(in oklab, var(--color-accent) 10%, transparent);"></div>

            @* Step 3 — Verify *@
            <div class="flex flex-col gap-4">
                <p class="text-xs" style="font-family: var(--font-display); color: var(--color-accent); letter-spacing: 0.1em;">STEP 3 — VERIFY</p>
                <p class="text-sm" style="color: var(--color-muted); font-family: var(--font-mono); line-height: 1.6;">
                    Once your app shows a 6-digit code for Shulker Tech, enter it below to confirm the setup.
                </p>

                <div asp-validation-summary="ModelOnly" class="text-xs p-3 rounded" role="alert"
                     style="color: var(--color-rune); background: color-mix(in oklab, var(--color-rune) 10%, transparent); border: 1px solid color-mix(in oklab, var(--color-rune) 30%, transparent); font-family: var(--font-mono); display: @(ViewData.ModelState.IsValid ? "none" : "block");">
                </div>

                <form id="send-code" method="post" class="flex flex-col gap-4">
                    <div class="flex flex-col gap-1">
                        <label asp-for="Input.Code" class="text-xs tracking-wider"
                               style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">VERIFICATION CODE</label>
                        <input asp-for="Input.Code" autocomplete="one-time-code" inputmode="numeric"
                               placeholder="123456"
                               class="w-full px-3 py-2 rounded text-sm"
                               style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent); color: var(--color-crystal); outline: none; max-width: 14rem; letter-spacing: 0.2em; font-family: var(--font-mono);"
                               onfocus="this.style.borderColor='var(--color-accent)'; this.style.boxShadow='0 0 8px color-mix(in oklab, var(--color-accent) 30%, transparent)';"
                               onblur="this.style.borderColor='color-mix(in oklab, var(--color-accent) 30%, transparent)'; this.style.boxShadow='none';" />
                        <span asp-validation-for="Input.Code" class="text-xs" style="color: var(--color-rune); font-family: var(--font-mono);"></span>
                    </div>

                    <button type="submit" class="btn-primary py-3 self-start px-8">
                        VERIFY &amp; ENABLE
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/qrcode/qrcode.min.js"></script>
    <script>
    new QRCode(document.getElementById('qr-code'), {
        text: @Json.Serialize(Model.AuthenticatorUri),
        width: 160,
        height: 160,
        colorDark: '#000000',
        colorLight: '#ffffff',
        correctLevel: QRCode.CorrectLevel.M
    });

    function copyKey() {
        var key = document.getElementById('shared-key').textContent.trim();
        navigator.clipboard.writeText(key).then(function () {
            var btn = event.currentTarget;
            btn.textContent = 'COPIED';
            setTimeout(function () { btn.textContent = 'COPY'; }, 1500);
        });
    }
    </script>
}
