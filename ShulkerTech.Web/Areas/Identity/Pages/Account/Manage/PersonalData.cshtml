@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="max-w-4xl mx-auto px-4 py-12">
    <div class="flex flex-col sm:flex-row gap-6">

        <aside class="sm:w-44 flex-shrink-0 panel p-4">
            <partial name="_ManageNav" />
        </aside>

        <div class="flex-1 panel p-8 flex flex-col gap-6">

            <h2 style="font-family: var(--font-display); font-size: 1rem; font-weight: 700; letter-spacing: 0.1em; color: var(--color-crystal);">PERSONAL DATA</h2>

            <p class="text-sm" style="color: var(--color-muted); font-family: var(--font-mono); line-height: 1.6;">
                Your account contains personal data that you have provided to us. This page allows you to download or permanently delete that data.
            </p>

            <div class="flex flex-col gap-3 pt-2" style="border-top: 1px solid color-mix(in oklab, var(--color-accent) 10%, transparent);">
                <form id="download-data" asp-page="DownloadPersonalData" method="post">
                    <button type="submit" class="btn-primary py-2 px-6">
                        DOWNLOAD MY DATA
                    </button>
                </form>

                <a asp-page="DeletePersonalData"
                   class="text-xs self-start"
                   style="color: var(--color-rune); font-family: var(--font-mono); text-decoration: none;"
                   onmouseover="this.style.textDecoration='underline';" onmouseout="this.style.textDecoration='none';">
                    Delete account and data &rarr;
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
