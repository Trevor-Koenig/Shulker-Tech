@using ShulkerTech.Core.Models
@inject SignInManager<ApplicationUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();

    string NavStyle(string navClass) =>
        navClass == "active"
            ? "font-family: var(--font-display); letter-spacing: 0.06em; color: var(--color-accent); background: color-mix(in oklab, var(--color-accent) 10%, transparent); text-decoration: none; display: block;"
            : "font-family: var(--font-display); letter-spacing: 0.06em; color: var(--color-muted); background: transparent; text-decoration: none; display: block;";
}

<nav class="flex flex-col gap-1">

    <a asp-page="./Index"
       class="text-xs px-3 py-2 rounded"
       style="@NavStyle(ManageNavPages.IndexNavClass(ViewContext))"
       onmouseover="if(!this.style.background.includes('plasma'))this.style.color='var(--color-crystal)';"
       onmouseout="this.style.color=this.style.background.includes('plasma')?'var(--color-accent)':'var(--color-muted)';">
        PROFILE
    </a>

    <a asp-page="./Email"
       class="text-xs px-3 py-2 rounded"
       style="@NavStyle(ManageNavPages.EmailNavClass(ViewContext))"
       onmouseover="if(!this.style.background.includes('plasma'))this.style.color='var(--color-crystal)';"
       onmouseout="this.style.color=this.style.background.includes('plasma')?'var(--color-accent)':'var(--color-muted)';">
        EMAIL
    </a>

    <a asp-page="./ChangePassword"
       class="text-xs px-3 py-2 rounded"
       style="@NavStyle(ManageNavPages.ChangePasswordNavClass(ViewContext))"
       onmouseover="if(!this.style.background.includes('plasma'))this.style.color='var(--color-crystal)';"
       onmouseout="this.style.color=this.style.background.includes('plasma')?'var(--color-accent)':'var(--color-muted)';">
        PASSWORD
    </a>

    @if (hasExternalLogins)
    {
        <a asp-page="./ExternalLogins"
           class="text-xs px-3 py-2 rounded"
           style="@NavStyle(ManageNavPages.ExternalLoginsNavClass(ViewContext))"
           onmouseover="if(!this.style.background.includes('plasma'))this.style.color='var(--color-crystal)';"
           onmouseout="this.style.color=this.style.background.includes('plasma')?'var(--color-accent)':'var(--color-muted)';">
            LINKED ACCOUNTS
        </a>
    }

    <a asp-page="./TwoFactorAuthentication"
       class="text-xs px-3 py-2 rounded"
       style="@NavStyle(ManageNavPages.TwoFactorAuthenticationNavClass(ViewContext))"
       onmouseover="if(!this.style.background.includes('plasma'))this.style.color='var(--color-crystal)';"
       onmouseout="this.style.color=this.style.background.includes('plasma')?'var(--color-accent)':'var(--color-muted)';">
        TWO-FACTOR AUTH
    </a>

    <a asp-page="./PersonalData"
       class="text-xs px-3 py-2 rounded"
       style="@NavStyle(ManageNavPages.PersonalDataNavClass(ViewContext))"
       onmouseover="if(!this.style.background.includes('plasma'))this.style.color='var(--color-crystal)';"
       onmouseout="this.style.color=this.style.background.includes('plasma')?'var(--color-accent)':'var(--color-muted)';">
        PERSONAL DATA
    </a>

</nav>
