@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="max-w-4xl mx-auto px-4 py-12">
    <div class="flex flex-col sm:flex-row gap-6">

        <aside class="sm:w-44 flex-shrink-0 panel p-4">
            <partial name="_ManageNav" />
        </aside>

        <div class="flex-1 panel p-8 flex flex-col gap-5">

            <h2 style="font-family: var(--font-display); font-size: 1rem; font-weight: 700; letter-spacing: 0.1em; color: var(--color-crystal);">PROFILE</h2>

            <partial name="_StatusMessage" for="StatusMessage" />

            <form id="profile-form" method="post" class="flex flex-col gap-4">

                <div asp-validation-summary="ModelOnly" class="text-xs p-3 rounded" role="alert"
                     style="color: var(--color-rune); background: color-mix(in oklab, var(--color-rune) 10%, transparent); border: 1px solid color-mix(in oklab, var(--color-rune) 30%, transparent); font-family: var(--font-mono); display: @(ViewData.ModelState.IsValid ? "none" : "block");">
                </div>

                <div class="flex flex-col gap-1">
                    <label asp-for="Username" class="text-xs tracking-wider"
                           style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">USERNAME</label>
                    <input asp-for="Username" disabled
                           class="w-full px-3 py-2 rounded text-sm"
                           style="background: color-mix(in oklab, var(--color-void) 50%, transparent); border: 1px solid color-mix(in oklab, var(--color-accent) 15%, transparent); color: var(--color-muted); cursor: not-allowed;" />
                </div>

                <div class="flex flex-col gap-1">
                    <label asp-for="Input.PhoneNumber" class="text-xs tracking-wider"
                           style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">PHONE NUMBER</label>
                    <input asp-for="Input.PhoneNumber" type="tel" autocomplete="tel"
                           placeholder="Optional"
                           class="w-full px-3 py-2 rounded text-sm"
                           style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent); color: var(--color-crystal); outline: none;"
                           onfocus="this.style.borderColor='var(--color-accent)'; this.style.boxShadow='0 0 8px color-mix(in oklab, var(--color-accent) 30%, transparent)';"
                           onblur="this.style.borderColor='color-mix(in oklab, var(--color-accent) 30%, transparent)'; this.style.boxShadow='none';" />
                    <span asp-validation-for="Input.PhoneNumber" class="text-xs" style="color: var(--color-rune); font-family: var(--font-mono);"></span>
                </div>

                <button id="update-profile-button" type="submit" class="btn-primary py-3 mt-1 self-start px-8">
                    SAVE CHANGES
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
