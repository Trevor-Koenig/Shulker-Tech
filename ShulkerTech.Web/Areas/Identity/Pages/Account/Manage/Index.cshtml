@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;

    var uuid = Model.MinecraftUuid?.Replace("-", "");
    var avatarUrl = uuid is not null ? $"https://api.mineatar.io/face/{uuid}?scale=12" : null;
}

<div class="max-w-4xl mx-auto px-4 py-12">
    <div class="flex flex-col sm:flex-row gap-6">

        <aside class="sm:w-44 flex-shrink-0 panel p-4">
            <partial name="_ManageNav" />
        </aside>

        <div class="flex-1 panel p-8 flex flex-col gap-6">

            <h2 style="font-family: var(--font-display); font-size: 1rem; font-weight: 700; letter-spacing: 0.1em; color: var(--color-crystal);">PROFILE</h2>

            <partial name="_StatusMessage" for="StatusMessage" />

            @* Current account info *@
            <div class="flex flex-col gap-1">
                <label class="text-xs tracking-wider"
                       style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">SITE USERNAME</label>
                <input value="@Model.Username" disabled
                       class="w-full px-3 py-2 rounded text-sm"
                       style="background: color-mix(in oklab, var(--color-void) 50%, transparent); border: 1px solid color-mix(in oklab, var(--color-accent) 15%, transparent); color: var(--color-muted); cursor: not-allowed;" />
            </div>

            <div style="border-top: 1px solid color-mix(in oklab, var(--color-accent) 10%, transparent);"></div>

            @* Current Minecraft account *@
            <div class="flex flex-col gap-3">
                <p class="text-xs tracking-wider" style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">MINECRAFT ACCOUNT</p>

                @if (Model.MinecraftUsername is not null)
                {
                    <div class="flex items-center gap-4 p-4 rounded"
                         style="background: color-mix(in oklab, var(--color-accent) 5%, transparent); border: 1px solid color-mix(in oklab, var(--color-accent) 15%, transparent);">
                        @if (avatarUrl is not null)
                        {
                            <img src="@avatarUrl" alt="@Model.MinecraftUsername skin" width="48" height="48"
                                 style="image-rendering: pixelated; border-radius: 4px; flex-shrink: 0;" />
                        }
                        <div>
                            <p style="font-family: var(--font-display); color: var(--color-crystal); letter-spacing: 0.06em; font-weight: 700;">@Model.MinecraftUsername</p>
                            <p class="text-xs mt-1" style="font-family: var(--font-mono); color: var(--color-muted);">@Model.MinecraftUuid</p>
                        </div>
                    </div>
                }
                else
                {
                    <p class="text-sm" style="font-family: var(--font-mono); color: var(--color-rune);">No Minecraft account linked.</p>
                }
            </div>

            @* Update form *@
            <form method="post" class="flex flex-col gap-4">

                <div asp-validation-summary="ModelOnly" class="text-xs p-3 rounded" role="alert"
                     style="color: var(--color-rune); background: color-mix(in oklab, var(--color-rune) 10%, transparent); border: 1px solid color-mix(in oklab, var(--color-rune) 30%, transparent); font-family: var(--font-mono); display: @(ViewData.ModelState.IsValid ? "none" : "block");">
                </div>

                <div class="flex flex-col gap-1">
                    <label asp-for="Input.MinecraftUsername" class="text-xs tracking-wider"
                           style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">NEW MINECRAFT USERNAME</label>
                    <input asp-for="Input.MinecraftUsername" autocomplete="off" placeholder="e.g. Notch"
                           class="w-full px-3 py-2 rounded text-sm"
                           style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent); color: var(--color-crystal); outline: none;"
                           onfocus="this.style.borderColor='var(--color-accent)'; this.style.boxShadow='0 0 8px color-mix(in oklab, var(--color-accent) 30%, transparent)';"
                           onblur="this.style.borderColor='color-mix(in oklab, var(--color-accent) 30%, transparent)'; this.style.boxShadow='none';" />
                    <span asp-validation-for="Input.MinecraftUsername" class="text-xs" style="color: var(--color-rune); font-family: var(--font-mono);"></span>
                    <p class="text-xs" style="color: var(--color-muted); font-family: var(--font-mono);">
                        Username will be verified against Mojang. The account cannot already be linked to another member.
                    </p>
                </div>

                <button type="submit" class="btn-primary py-3 self-start px-8">
                    UPDATE MINECRAFT ACCOUNT
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
