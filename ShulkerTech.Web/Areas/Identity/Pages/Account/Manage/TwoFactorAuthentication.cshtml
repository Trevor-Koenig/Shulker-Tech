@page
@model TwoFactorAuthenticationModel
@{
    ViewData["Title"] = "Two-Factor Authentication";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<div class="max-w-4xl mx-auto px-4 py-12">
    <div class="flex flex-col sm:flex-row gap-6">

        <aside class="sm:w-44 flex-shrink-0 panel p-4">
            <partial name="_ManageNav" />
        </aside>

        <div class="flex-1 panel p-8 flex flex-col gap-6">

            <h2 style="font-family: var(--font-display); font-size: 1rem; font-weight: 700; letter-spacing: 0.1em; color: var(--color-crystal);">TWO-FACTOR AUTHENTICATION</h2>

            <partial name="_StatusMessage" for="StatusMessage" />

            @* Status badge *@
            <div class="flex items-center gap-3 p-4 rounded"
                 style="background: color-mix(in oklab, @(Model.Is2faEnabled ? "var(--color-arcane)" : "var(--color-muted)") 8%, transparent);
                        border: 1px solid color-mix(in oklab, @(Model.Is2faEnabled ? "var(--color-arcane)" : "var(--color-muted)") 25%, transparent);">
                <span style="font-size: 1.25rem;">@(Model.Is2faEnabled ? "🔒" : "🔓")</span>
                <div>
                    <p style="font-family: var(--font-display); font-size: 0.75rem; letter-spacing: 0.08em;
                               color: @(Model.Is2faEnabled ? "var(--color-arcane)" : "var(--color-muted)");">
                        @(Model.Is2faEnabled ? "2FA ENABLED" : "2FA DISABLED")
                    </p>
                    @if (Model.Is2faEnabled)
                    {
                        <p class="text-xs mt-0.5" style="font-family: var(--font-mono); color: var(--color-muted);">
                            @Model.RecoveryCodesLeft recovery code@(Model.RecoveryCodesLeft != 1 ? "s" : "") remaining
                        </p>
                    }
                </div>
            </div>

            @if (!Model.HasAuthenticator)
            {
                <div class="flex flex-col gap-3">
                    <p class="text-sm" style="color: var(--color-muted); font-family: var(--font-mono); line-height: 1.6;">
                        You do not have an authenticator app configured. Add an authenticator app to use two-factor authentication.
                    </p>
                    <a asp-page="./EnableAuthenticator" class="btn-primary py-2 px-6 self-start text-center">
                        SET UP AUTHENTICATOR
                    </a>
                </div>
            }
            else
            {
                <div class="flex flex-col gap-3">
                    @if (Model.Is2faEnabled)
                    {
                        @if (Model.RecoveryCodesLeft == 0)
                        {
                            <div class="text-xs p-3 rounded" style="color: var(--color-rune); background: color-mix(in oklab, var(--color-rune) 10%, transparent); border: 1px solid color-mix(in oklab, var(--color-rune) 30%, transparent); font-family: var(--font-mono);">
                                You have no recovery codes remaining. Generate new ones below before you lose access.
                            </div>
                        }
                        else if (Model.RecoveryCodesLeft <= 3)
                        {
                            <div class="text-xs p-3 rounded" style="color: var(--color-rune); background: color-mix(in oklab, var(--color-rune) 10%, transparent); border: 1px solid color-mix(in oklab, var(--color-rune) 30%, transparent); font-family: var(--font-mono);">
                                Only @Model.RecoveryCodesLeft recovery code@(Model.RecoveryCodesLeft != 1 ? "s" : "") left. Generate new ones soon.
                            </div>
                        }

                        <div class="flex flex-wrap gap-3">
                            <a asp-page="./Disable2fa" class="btn-nav py-2 px-5 text-center"
                               style="background: linear-gradient(135deg, var(--color-redstone-dim), color-mix(in oklab, var(--color-redstone) 60%, transparent));">
                                DISABLE 2FA
                            </a>
                            <a asp-page="./GenerateRecoveryCodes" class="btn-nav py-2 px-5 text-center">
                                GENERATE RECOVERY CODES
                            </a>
                        </div>
                    }

                    <div style="border-top: 1px solid color-mix(in oklab, var(--color-accent) 10%, transparent); padding-top: 1rem;" class="flex flex-col gap-2">
                        <p class="text-xs" style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">AUTHENTICATOR APP</p>
                        <div class="flex flex-wrap gap-3">
                            <a asp-page="./EnableAuthenticator" class="btn-nav py-2 px-5 text-center">
                                @(Model.Is2faEnabled ? "RECONFIGURE" : "ENABLE") AUTHENTICATOR
                            </a>
                            <a asp-page="./ResetAuthenticator" class="btn-nav py-2 px-5 text-center"
                               style="background: linear-gradient(135deg, color-mix(in oklab, var(--color-rune) 60%, transparent), color-mix(in oklab, var(--color-arcane-dim) 40%, transparent));">
                                RESET AUTHENTICATOR KEY
                            </a>
                        </div>
                    </div>

                    @if (Model.Is2faEnabled && Model.IsMachineRemembered)
                    {
                        <div style="border-top: 1px solid color-mix(in oklab, var(--color-accent) 10%, transparent); padding-top: 1rem;">
                            <p class="text-xs mb-3" style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">TRUSTED MACHINES</p>
                            <form method="post">
                                <button type="submit" class="btn-nav py-2 px-5">
                                    FORGET THIS BROWSER
                                </button>
                            </form>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
