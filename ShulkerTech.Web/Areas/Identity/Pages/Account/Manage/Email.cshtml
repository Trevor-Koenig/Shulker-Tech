@page
@model EmailModel
@{
    ViewData["Title"] = "Email";
    ViewData["ActivePage"] = ManageNavPages.Email;
}

<div class="max-w-4xl mx-auto px-4 py-12">
    <div class="flex flex-col sm:flex-row gap-6">

        <aside class="sm:w-44 flex-shrink-0 panel p-4">
            <partial name="_ManageNav" />
        </aside>

        <div class="flex-1 panel p-8 flex flex-col gap-5">

            <h2 style="font-family: var(--font-display); font-size: 1rem; font-weight: 700; letter-spacing: 0.1em; color: var(--color-crystal);">EMAIL</h2>

            <partial name="_StatusMessage" for="StatusMessage" />

            <form id="email-form" method="post" class="flex flex-col gap-4">

                <div asp-validation-summary="All" class="text-xs p-3 rounded" role="alert"
                     style="color: var(--color-rune); background: color-mix(in oklab, var(--color-rune) 10%, transparent); border: 1px solid color-mix(in oklab, var(--color-rune) 30%, transparent); font-family: var(--font-mono); display: @(ViewData.ModelState.IsValid ? "none" : "block");">
                </div>

                <div class="flex flex-col gap-1">
                    <label asp-for="Email" class="text-xs tracking-wider"
                           style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">
                        CURRENT EMAIL
                        @if (Model.IsEmailConfirmed)
                        {
                            <span class="ml-2" style="color: var(--color-arcane);">&#10003; VERIFIED</span>
                        }
                        else
                        {
                            <span class="ml-2" style="color: var(--color-rune);">UNVERIFIED</span>
                        }
                    </label>
                    <div class="flex gap-2 items-center">
                        <input asp-for="Email" disabled
                               class="flex-1 px-3 py-2 rounded text-sm"
                               style="background: color-mix(in oklab, var(--color-void) 50%, transparent); border: 1px solid color-mix(in oklab, var(--color-accent) 15%, transparent); color: var(--color-muted); cursor: not-allowed;" />
                        @if (!Model.IsEmailConfirmed)
                        {
                            <button type="submit" asp-page-handler="SendVerificationEmail"
                                    class="text-xs px-3 py-2 rounded flex-shrink-0"
                                    style="font-family: var(--font-display); letter-spacing: 0.06em; color: var(--color-arcane); border: 1px solid color-mix(in oklab, var(--color-arcane) 40%, transparent); background: transparent; cursor: pointer;"
                                    onmouseover="this.style.background='color-mix(in oklab, var(--color-arcane) 10%, transparent)';"
                                    onmouseout="this.style.background='transparent';">
                                VERIFY
                            </button>
                        }
                    </div>
                </div>

                <div class="flex flex-col gap-1">
                    <label asp-for="Input.NewEmail" class="text-xs tracking-wider"
                           style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">NEW EMAIL</label>
                    <input asp-for="Input.NewEmail" type="email" autocomplete="email" aria-required="true"
                           placeholder="new@example.com"
                           class="w-full px-3 py-2 rounded text-sm"
                           style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent); color: var(--color-crystal); outline: none;"
                           onfocus="this.style.borderColor='var(--color-accent)'; this.style.boxShadow='0 0 8px color-mix(in oklab, var(--color-accent) 30%, transparent)';"
                           onblur="this.style.borderColor='color-mix(in oklab, var(--color-accent) 30%, transparent)'; this.style.boxShadow='none';" />
                    <span asp-validation-for="Input.NewEmail" class="text-xs" style="color: var(--color-rune); font-family: var(--font-mono);"></span>
                </div>

                <button id="change-email-button" type="submit" asp-page-handler="ChangeEmail" class="btn-primary py-3 mt-1 self-start px-8">
                    CHANGE EMAIL
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
