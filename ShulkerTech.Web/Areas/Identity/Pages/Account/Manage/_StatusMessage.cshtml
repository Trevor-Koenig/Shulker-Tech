@model string
@if (!string.IsNullOrEmpty(Model))
{
    var isError = Model.StartsWith("Error");
    <div class="text-xs p-3 rounded mb-4" role="alert"
         style="font-family: var(--font-mono);
                color: @(isError ? "var(--color-rune)" : "var(--color-arcane)");
                background: @(isError ? "color-mix(in oklab, var(--color-rune) 10%, transparent)" : "color-mix(in oklab, var(--color-arcane) 10%, transparent)");
                border: 1px solid @(isError ? "color-mix(in oklab, var(--color-rune) 30%, transparent)" : "color-mix(in oklab, var(--color-arcane) 30%, transparent)");">
        @Model
    </div>
}
