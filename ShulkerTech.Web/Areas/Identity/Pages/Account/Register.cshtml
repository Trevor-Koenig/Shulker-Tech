@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="min-h-screen flex items-center justify-center px-4 py-16"
     style="background: radial-gradient(ellipse at 50% 0%, color-mix(in oklab, var(--color-nebula) 60%, transparent), var(--color-void) 70%);">

    <div class="w-full max-w-sm">

        @* Header *@
        <div class="text-center mb-8">
            <p class="text-xs tracking-widest mb-3" style="font-family: var(--font-mono); color: var(--color-accent);">&#9670; SHULKER TECH &#9670;</p>
            <h1 style="font-family: var(--font-display); font-size: 1.75rem; font-weight: 900; letter-spacing: 0.1em; color: var(--color-crystal);">
                ENLIST
            </h1>
        </div>

        @* Card *@
        <div class="panel p-8 flex flex-col gap-5">

            @* Validation errors *@
            <div asp-validation-summary="ModelOnly" class="text-xs p-3 rounded" role="alert"
                 style="color: var(--color-rune); background: color-mix(in oklab, var(--color-rune) 10%, transparent); border: 1px solid color-mix(in oklab, var(--color-rune) 30%, transparent); font-family: var(--font-mono); display: @(ViewData.ModelState.IsValid ? "none" : "block");">
            </div>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="flex flex-col gap-4">

                @* Email *@
                <div class="flex flex-col gap-1">
                    <label asp-for="Input.Email" class="text-xs tracking-wider"
                           style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">EMAIL <span style="color: var(--color-rune);">*</span></label>
                    <input asp-for="Input.Email" type="email" autocomplete="username" aria-required="true"
                           placeholder="commander@example.com"
                           class="w-full px-3 py-2 rounded text-sm"
                           style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent); color: var(--color-crystal); outline: none;"
                           onfocus="this.style.borderColor='var(--color-accent)'; this.style.boxShadow='0 0 8px color-mix(in oklab, var(--color-accent) 30%, transparent)';"
                           onblur="this.style.borderColor='color-mix(in oklab, var(--color-accent) 30%, transparent)'; this.style.boxShadow='none';" />
                    <span asp-validation-for="Input.Email" class="text-xs" style="color: var(--color-rune); font-family: var(--font-mono);"></span>
                </div>

                @* Password *@
                <div class="flex flex-col gap-1">
                    <label asp-for="Input.Password" class="text-xs tracking-wider"
                           style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">PASSWORD <span style="color: var(--color-rune);">*</span></label>
                    <input asp-for="Input.Password" type="password" autocomplete="new-password" aria-required="true"
                           placeholder="••••••••"
                           class="w-full px-3 py-2 rounded text-sm"
                           style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent); color: var(--color-crystal); outline: none;"
                           onfocus="this.style.borderColor='var(--color-accent)'; this.style.boxShadow='0 0 8px color-mix(in oklab, var(--color-accent) 30%, transparent)';"
                           onblur="this.style.borderColor='color-mix(in oklab, var(--color-accent) 30%, transparent)'; this.style.boxShadow='none';" />
                    <span asp-validation-for="Input.Password" class="text-xs" style="color: var(--color-rune); font-family: var(--font-mono);"></span>
                </div>

                @* Confirm password *@
                <div class="flex flex-col gap-1">
                    <label asp-for="Input.ConfirmPassword" class="text-xs tracking-wider"
                           style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">CONFIRM PASSWORD <span style="color: var(--color-rune);">*</span></label>
                    <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" aria-required="true"
                           placeholder="••••••••"
                           class="w-full px-3 py-2 rounded text-sm"
                           style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent); color: var(--color-crystal); outline: none;"
                           onfocus="this.style.borderColor='var(--color-accent)'; this.style.boxShadow='0 0 8px color-mix(in oklab, var(--color-accent) 30%, transparent)';"
                           onblur="this.style.borderColor='color-mix(in oklab, var(--color-accent) 30%, transparent)'; this.style.boxShadow='none';" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-xs" style="color: var(--color-rune); font-family: var(--font-mono);"></span>
                </div>

                @* Invite code *@
                <div class="flex flex-col gap-1">
                    <label asp-for="Input.InviteCode" class="text-xs tracking-wider"
                           style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">INVITE CODE <span style="color: var(--color-rune);">*</span></label>
                    <input asp-for="Input.InviteCode" type="text" autocomplete="off" aria-required="true"
                           placeholder="XXXX-XXXX-XXXX"
                           class="w-full px-3 py-2 rounded text-sm tracking-widest"
                           style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent); color: var(--color-crystal); outline: none; font-family: var(--font-mono);"
                           onfocus="this.style.borderColor='var(--color-accent)'; this.style.boxShadow='0 0 8px color-mix(in oklab, var(--color-accent) 30%, transparent)';"
                           onblur="this.style.borderColor='color-mix(in oklab, var(--color-accent) 30%, transparent)'; this.style.boxShadow='none';" />
                    <span asp-validation-for="Input.InviteCode" class="text-xs" style="color: var(--color-rune); font-family: var(--font-mono);"></span>
                </div>

                @* Divider *@
                <div class="flex items-center gap-3">
                    <div class="flex-1 h-px" style="background: color-mix(in oklab, var(--color-accent) 15%, transparent);"></div>
                    <span class="text-xs" style="color: var(--color-muted); font-family: var(--font-mono);">MINECRAFT</span>
                    <div class="flex-1 h-px" style="background: color-mix(in oklab, var(--color-accent) 15%, transparent);"></div>
                </div>

                @* Minecraft username *@
                <div class="flex flex-col gap-1">
                    <label asp-for="Input.MinecraftUsername" class="text-xs tracking-wider"
                           style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">MINECRAFT USERNAME <span style="color: var(--color-rune);">*</span></label>
                    <input asp-for="Input.MinecraftUsername" type="text" autocomplete="off" aria-required="true"
                           placeholder="Steve"
                           class="w-full px-3 py-2 rounded text-sm"
                           style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-arcane) 30%, transparent); color: var(--color-crystal); outline: none;"
                           onfocus="this.style.borderColor='var(--color-arcane)'; this.style.boxShadow='0 0 8px color-mix(in oklab, var(--color-arcane) 30%, transparent)';"
                           onblur="this.style.borderColor='color-mix(in oklab, var(--color-arcane) 30%, transparent)'; this.style.boxShadow='none';" />
                    <span asp-validation-for="Input.MinecraftUsername" class="text-xs" style="color: var(--color-rune); font-family: var(--font-mono);"></span>
                </div>

                <button type="submit" class="btn-primary w-full py-3 mt-1">
                    CREATE ACCOUNT
                </button>
            </form>

            @* External logins *@
            @if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <div class="flex items-center gap-3 my-1">
                    <div class="flex-1 h-px" style="background: color-mix(in oklab, var(--color-accent) 15%, transparent);"></div>
                    <span class="text-xs" style="color: var(--color-muted); font-family: var(--font-mono);">OR</span>
                    <div class="flex-1 h-px" style="background: color-mix(in oklab, var(--color-accent) 15%, transparent);"></div>
                </div>
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="flex flex-col gap-2">
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit" name="provider" value="@provider.Name"
                                class="w-full py-2 rounded text-xs"
                                style="font-family: var(--font-display); letter-spacing: 0.08em; color: var(--color-crystal);
                                       border: 1px solid color-mix(in oklab, var(--color-crystal) 20%, transparent);
                                       transition: border-color 150ms, color 150ms;"
                                onmouseover="this.style.borderColor='var(--color-arcane)'; this.style.color='var(--color-arcane)';"
                                onmouseout="this.style.borderColor='color-mix(in oklab, var(--color-crystal) 20%, transparent)'; this.style.color='var(--color-crystal)';">
                            CONTINUE WITH @provider.DisplayName?.ToUpper()
                        </button>
                    }
                </form>
            }

            @* Footer links *@
            <div class="pt-2 text-center" style="border-top: 1px solid color-mix(in oklab, var(--color-accent) 10%, transparent);">
                <a asp-page="./Login"
                   class="text-xs" style="color: var(--color-accent); font-family: var(--font-mono); text-decoration: none;"
                   onmouseover="this.style.textDecoration='underline';" onmouseout="this.style.textDecoration='none';">
                    Already enlisted? Sign in
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
