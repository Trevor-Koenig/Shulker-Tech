@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="min-h-screen flex items-center justify-center px-4 py-16"
     style="background: radial-gradient(ellipse at 50% 0%, color-mix(in oklab, var(--color-nebula) 60%, transparent), var(--color-void) 70%);">

    <div class="w-full max-w-sm">

        <div class="text-center mb-8">
            <p class="text-xs tracking-widest mb-3" style="font-family: var(--font-mono); color: var(--color-plasma);">&#9670; SHULKER TECH &#9670;</p>
            <h1 style="font-family: var(--font-display); font-size: 1.75rem; font-weight: 900; letter-spacing: 0.1em; color: var(--color-crystal);">
                RESET PASSWORD
            </h1>
        </div>

        <div class="panel p-8 flex flex-col gap-5">

            <div asp-validation-summary="ModelOnly" class="text-xs p-3 rounded" role="alert"
                 style="color: var(--color-rune); background: color-mix(in oklab, var(--color-rune) 10%, transparent); border: 1px solid color-mix(in oklab, var(--color-rune) 30%, transparent); font-family: var(--font-mono); display: @(ViewData.ModelState.IsValid ? "none" : "block");">
            </div>

            <p class="text-xs" style="color: var(--color-muted); font-family: var(--font-mono); line-height: 1.6;">
                Enter your email address and we will send you a link to reset your password.
            </p>

            <form method="post" class="flex flex-col gap-4">

                <div class="flex flex-col gap-1">
                    <label asp-for="Input.Email" class="text-xs tracking-wider"
                           style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">EMAIL</label>
                    <input asp-for="Input.Email" type="email" autocomplete="username" aria-required="true"
                           placeholder="commander@example.com"
                           class="w-full px-3 py-2 rounded text-sm"
                           style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-plasma) 30%, transparent); color: var(--color-crystal); outline: none;"
                           onfocus="this.style.borderColor='var(--color-plasma)'; this.style.boxShadow='0 0 8px color-mix(in oklab, var(--color-plasma) 30%, transparent)';"
                           onblur="this.style.borderColor='color-mix(in oklab, var(--color-plasma) 30%, transparent)'; this.style.boxShadow='none';" />
                    <span asp-validation-for="Input.Email" class="text-xs" style="color: var(--color-rune); font-family: var(--font-mono);"></span>
                </div>

                <button type="submit" class="btn-primary w-full py-3 mt-1">
                    SEND RESET LINK
                </button>
            </form>

            <div class="pt-2 text-center" style="border-top: 1px solid color-mix(in oklab, var(--color-plasma) 10%, transparent);">
                <a asp-page="./Login"
                   class="text-xs" style="color: var(--color-plasma); font-family: var(--font-mono); text-decoration: none;"
                   onmouseover="this.style.textDecoration='underline';" onmouseout="this.style.textDecoration='none';">
                    &larr; Back to sign in
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
