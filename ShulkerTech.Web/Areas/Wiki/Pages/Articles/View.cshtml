@page "/Wiki/articles/{slug}"
@model ViewModel
@{
    ViewData["Title"] = Model.Article.Title;
}

<div class="wiki-outer">

    <!-- Breadcrumb -->
    <nav class="mb-6 flex items-center gap-2" style="font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.08em; color: var(--color-muted);">
        <a href="/" style="color: var(--color-muted); text-decoration: none; transition: color 120ms ease;" onmouseover="this.style.color='var(--color-accent)'" onmouseout="this.style.color='var(--color-muted)'">WIKI</a>
        <span style="color: var(--color-accent); opacity: 0.6;">›</span>
        <span id="wiki-breadcrumb-title" style="color: var(--color-crystal); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@Model.Article.Title.ToUpperInvariant()</span>
    </nav>

    <!-- Two-column layout: content + TOC -->
    <div style="display: grid; grid-template-columns: 1fr; gap: 2rem;" id="wiki-layout">

        <!-- Main content -->
        <div id="wiki-main">

            <!-- Article header -->
            <div class="mb-6" style="border-bottom: 1px solid color-mix(in oklab, var(--color-accent) 15%, transparent); padding-bottom: 1.25rem;">
                @if (!Model.Article.IsPublished)
                {
                    <span class="inline-block mb-3 text-xs px-2 py-0.5 rounded"
                          style="font-family: var(--font-mono); background: color-mix(in oklab, var(--color-redstone) 15%, transparent); color: var(--color-redstone); letter-spacing: 0.08em;">
                        DRAFT — NOT PUBLISHED
                    </span>
                }
                <h1 class="wiki-article-title" style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; letter-spacing: 0.06em; color: var(--color-crystal); line-height: 1.2;">
                    @Model.Article.Title
                </h1>
                <div class="mt-3 flex flex-wrap items-center gap-4">
                    <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted);">
                        BY @((Model.Article.Author?.MinecraftUsername ?? Model.Article.Author?.UserName)?.ToUpperInvariant() ?? "UNKNOWN")
                    </span>
                    <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted);">
                        UPDATED @Model.Article.UpdatedAt.ToString("MMM d, yyyy").ToUpper()
                    </span>
                    @if (Model.CanEdit)
                    {
                        <a href="/articles/edit/@Model.Article.Id" class="btn-nav"
                           style="font-size: 0.65rem; padding: 0.2rem 0.6rem;">EDIT</a>
                        <a href="/articles/history/@Model.Article.Id" class="btn-nav"
                           style="font-size: 0.65rem; padding: 0.2rem 0.6rem;">HISTORY</a>
                    }
                </div>
                @if (Model.Article.Tags.Any())
                {
                    <div class="mt-3 flex flex-wrap gap-2">
                        @foreach (var tag in Model.Article.Tags.OrderBy(t => t.Name))
                        {
                            <a href="/?tag=@tag.Slug" class="tag-pill" style="--tag-color: @tag.Color; text-decoration: none;">
                                <span>@tag.Icon</span> @tag.Name.ToUpperInvariant()
                            </a>
                        }
                    </div>
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Article.MapUrl))
            {
                <details id="map-details" class="panel mb-6" style="overflow: hidden;">
                    <summary style="padding: 0.75rem 1.25rem; cursor: pointer; font-family: var(--font-display);
                                    font-size: 0.75rem; letter-spacing: 0.12em; color: var(--color-accent);
                                    list-style: none; display: flex; align-items: center; gap: 0.5rem; user-select: none;">
                        <span>&#9670;</span> VIEW ON MAP
                    </summary>
                    <div style="height: 720px; border-top: 1px solid color-mix(in oklab, var(--color-accent) 15%, transparent);">
                        <iframe src="@Model.Article.MapUrl"
                                style="width: 100%; height: 100%; border: none;"
                                loading="lazy"
                                title="BlueMap — @Model.Article.Title"
                                sandbox="allow-scripts allow-same-origin allow-popups">
                        </iframe>
                    </div>
                </details>
            }

            <!-- Article content -->
            <div class="panel wiki-content" style="padding: 2.5rem;">
                @Html.Raw(Model.ContentHtml)
            </div>

        </div>

        <!-- TOC sidebar — hidden until JS builds it, visible only on large screens -->
        <aside id="toc-sidebar" style="display: none;">
            <div class="panel p-4" style="position: sticky; top: 5.5rem;">
                <p style="font-family: var(--font-display); font-size: 0.68rem; letter-spacing: 0.12em; color: var(--color-accent); margin-bottom: 0.75rem; text-transform: uppercase;">Contents</p>
                <nav id="toc-nav"></nav>
            </div>
        </aside>

    </div>

</div>

@section Scripts {
<script>
// Persist map panel open/closed state in localStorage
(function () {
    var mapDetails = document.getElementById('map-details');
    if (!mapDetails) return;
    var KEY = 'wiki-map-open';
    if (localStorage.getItem(KEY) === 'true') mapDetails.open = true;
    mapDetails.addEventListener('toggle', function () {
        localStorage.setItem(KEY, mapDetails.open ? 'true' : 'false');
    });
})();

(function () {
    var content = document.querySelector('.wiki-content');
    var tocNav  = document.getElementById('toc-nav');
    var sidebar = document.getElementById('toc-sidebar');
    var layout  = document.getElementById('wiki-layout');
    if (!content || !tocNav || !sidebar || !layout) return;

    // Collect h2 / h3 headings that have an id
    var headings = Array.from(content.querySelectorAll('h2[id], h3[id]'));
    if (headings.length < 2) return; // not worth showing TOC for very short articles

    // Build TOC links
    headings.forEach(function (h) {
        var a = document.createElement('a');
        a.href = '#' + h.id;
        a.textContent = h.textContent;
        a.className = 'wiki-toc-link' + (h.tagName === 'H3' ? ' toc-h3' : '');
        tocNav.appendChild(a);
    });

    // Show sidebar and switch layout to two columns (only on large-enough viewports)
    function applyLayout() {
        if (window.innerWidth >= 1400) {
            sidebar.style.display = 'block';
            layout.style.gridTemplateColumns = '1fr 320px';
        } else if (window.innerWidth >= 800) {
            sidebar.style.display = 'block';
            layout.style.gridTemplateColumns = '1fr 280px';
        } else {
            sidebar.style.display = 'none';
            layout.style.gridTemplateColumns = '1fr';
        }
    }
    applyLayout();
    window.addEventListener('resize', applyLayout);

    // Scroll spy
    var links = Array.from(tocNav.querySelectorAll('.wiki-toc-link'));
    var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
            if (entry.isIntersecting) {
                var id = entry.target.id;
                links.forEach(function (l) {
                    l.classList.toggle('toc-active', l.getAttribute('href') === '#' + id);
                });
            }
        });
    }, { rootMargin: '-10% 0px -80% 0px' });

    headings.forEach(function (h) { observer.observe(h); });
})();
</script>
}
