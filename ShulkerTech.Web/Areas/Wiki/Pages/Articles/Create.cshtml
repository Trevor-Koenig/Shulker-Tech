@page "/Wiki/articles/create"
@model CreateModel
@{
    ViewData["Title"] = "New Article";
}

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- Header -->
    <div class="mb-8">
        <a href="/" style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-muted); letter-spacing: 0.08em; text-decoration: none;">← WIKI</a>
        <p class="text-xs tracking-widest mt-4 mb-2" style="font-family: var(--font-mono); color: var(--color-rune);">&#9670; NEW ARTICLE</p>
        <h1 style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; letter-spacing: 0.08em; color: var(--color-crystal);">
            CREATE ARTICLE
        </h1>
    </div>

    <form method="post" class="flex flex-col gap-6">
        <div asp-validation-summary="ModelOnly" class="text-sm panel p-4"
             style="color: var(--color-redstone); font-family: var(--font-mono);"></div>

        <!-- Title -->
        <div class="flex flex-col gap-2">
            <label asp-for="Input.Title" class="text-xs"
                   style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.1em;">TITLE</label>
            <input asp-for="Input.Title" id="title-input" autocomplete="off"
                   class="panel px-4 py-3 w-full bg-transparent outline-none"
                   style="font-family: var(--font-display); color: var(--color-crystal); font-size: 1.1rem; letter-spacing: 0.04em;" />
            <p class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted);">
                SLUG: <span id="slug-preview" style="color: var(--color-accent);">—</span>
            </p>
            <span asp-validation-for="Input.Title" class="text-xs"
                  style="color: var(--color-redstone); font-family: var(--font-mono);"></span>
        </div>

        <!-- Content -->
        <div class="flex flex-col gap-2">
            <div class="flex items-center justify-between">
                <label asp-for="Input.Content" class="text-xs"
                       style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.1em;">CONTENT</label>
                <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted); opacity: 0.7;">
                    Markdown supported — **bold**, # Heading, [link](url), `code`
                </span>
            </div>
            <textarea asp-for="Input.Content" rows="28"
                      class="panel px-4 py-3 w-full bg-transparent outline-none resize-y"
                      style="font-family: var(--font-mono); color: var(--color-crystal); font-size: 0.875rem; line-height: 1.7;"
                      placeholder="## Introduction&#10;&#10;Write your article here using Markdown..."></textarea>
            <span asp-validation-for="Input.Content" class="text-xs"
                  style="color: var(--color-redstone); font-family: var(--font-mono);"></span>
        </div>

        <!-- Publish toggle -->
        <label class="flex items-center gap-3 cursor-pointer select-none">
            <input asp-for="Input.IsPublished" type="checkbox"
                   class="w-4 h-4" style="accent-color: var(--color-accent);" />
            <span class="text-xs" style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.1em;">
                PUBLISH IMMEDIATELY
            </span>
        </label>

        <!-- Actions -->
        <div class="flex items-center gap-4 pt-2">
            <button type="submit" class="btn-primary">SAVE ARTICLE</button>
            <a href="/" class="nav-link">CANCEL</a>
        </div>
    </form>

</div>

@section Scripts {
    <script>
        document.getElementById('title-input').addEventListener('input', function () {
            var slug = this.value.toLowerCase()
                .replace(/[^a-z0-9\s]/g, '')
                .trim()
                .replace(/\s+/g, '-');
            document.getElementById('slug-preview').textContent = slug || '—';
        });
    </script>
}
