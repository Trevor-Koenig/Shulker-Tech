@page "/Wiki/articles/create"
@model CreateModel
@{
    ViewData["Title"] = "New Article";
}

<div class="px-4 sm:px-8 lg:px-16 xl:px-24 2xl:px-32 py-10">

    <!-- Header -->
    <div class="mb-8">
        <a href="/" style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-muted); letter-spacing: 0.08em; text-decoration: none;">← WIKI</a>
        <p class="text-xs tracking-widest mt-4 mb-2" style="font-family: var(--font-mono); color: var(--color-rune);">&#9670; NEW ARTICLE</p>
        <h1 style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; letter-spacing: 0.08em; color: var(--color-crystal);">
            CREATE ARTICLE
        </h1>
    </div>

    <form method="post" class="flex flex-col gap-6">
        <div asp-validation-summary="ModelOnly" class="text-sm panel p-4"
             style="color: var(--color-redstone); font-family: var(--font-mono);"></div>

        <!-- Title -->
        <div class="flex flex-col gap-2">
            <label asp-for="Input.Title" class="text-xs"
                   style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.1em;">TITLE</label>
            <input asp-for="Input.Title" id="title-input" autocomplete="off"
                   class="panel px-4 py-3 w-full bg-transparent outline-none"
                   style="font-family: var(--font-display); color: var(--color-crystal); font-size: 1.1rem; letter-spacing: 0.04em;" />
            <p class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted);">
                SLUG: <span id="slug-preview" style="color: var(--color-accent);">—</span>
            </p>
            <span asp-validation-for="Input.Title" class="text-xs"
                  style="color: var(--color-redstone); font-family: var(--font-mono);"></span>
        </div>

        <!-- Template picker -->
        @if (Model.Templates.Count > 0)
        {
            <div class="flex flex-col gap-2">
                <div style="display: flex; align-items: baseline; gap: 0.75rem; flex-wrap: wrap;">
                    <label class="text-xs" style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.1em;">TEMPLATE</label>
                    <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted); opacity: 0.6;">Click to load · ★ = default</span>
                </div>
                <div class="flex flex-wrap gap-2" id="template-btns">
                    @foreach (var tmpl in Model.Templates)
                    {
                        <button type="button"
                                class="btn-nav template-load-btn"
                                data-template-id="@tmpl.Id"
                                style="font-size: 0.78rem; @(tmpl.IsDefault ? "color: var(--color-plasma); border-color: var(--color-plasma);" : "")">
                            @(tmpl.IsDefault ? "★ " : "")@tmpl.Name
                        </button>
                    }
                </div>
            </div>
        }

        <!-- Content -->
        <div class="flex flex-col gap-2">
            <div class="flex items-center justify-between">
                <label asp-for="Input.Content" class="text-xs"
                       style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.1em;">CONTENT</label>
                <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted); opacity: 0.7;">
                    Markdown — **bold**, # Heading, `code`, ![Caption|right|thumb](url)
                </span>
            </div>
            <textarea asp-for="Input.Content" id="content-editor" rows="28"
                      class="panel px-4 py-3 w-full bg-transparent outline-none resize-y"
                      style="font-family: var(--font-mono); color: var(--color-crystal); font-size: 0.875rem; line-height: 1.7;"
                      placeholder="## Introduction&#10;&#10;Write your article here using Markdown..."></textarea>
            <span asp-validation-for="Input.Content" class="text-xs"
                  style="color: var(--color-redstone); font-family: var(--font-mono);"></span>
        </div>

        <!-- Tags -->
        <div class="flex flex-col gap-2">
            <label class="text-xs" style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.1em;">
                TAGS <span style="opacity: 0.5; font-size: 0.65rem;">(OPTIONAL — CLICK TO SELECT)</span>
            </label>
            <input type="hidden" asp-for="Input.TagIds" id="tag-ids-input" />
            <div class="flex flex-wrap gap-2">
                @foreach (var tag in Model.AllTags)
                {
                    <button type="button" class="tag-pill"
                            data-tag-id="@tag.Id"
                            style="--tag-color: @tag.Color;">
                        @if (!string.IsNullOrEmpty(tag.Icon)) { @tag.Icon } @tag.Name
                    </button>
                }
            </div>
        </div>

        <!-- BlueMap URL -->
        <div class="flex flex-col gap-2">
            <label asp-for="Input.MapUrl" class="text-xs"
                   style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.1em;">
                BLUEMAP URL <span style="opacity: 0.5; font-size: 0.65rem;">(OPTIONAL)</span>
            </label>
            <input asp-for="Input.MapUrl" type="url" autocomplete="off"
                   class="panel px-4 py-2.5 w-full bg-transparent outline-none"
                   style="font-family: var(--font-mono); color: var(--color-crystal); font-size: 0.875rem;"
                   placeholder="https://map.shulkertech.com/#world:0:64:0:300:0:0:0:0:perspective" />
            <span asp-validation-for="Input.MapUrl" class="text-xs"
                  style="color: var(--color-redstone); font-family: var(--font-mono);"></span>
            <p class="text-xs" style="color: var(--color-muted); font-family: var(--font-mono); opacity: 0.7;">
                Paste a BlueMap link to embed a live map panel on this article. Right-click the map → Copy Link.
            </p>
        </div>

        <!-- Permissions -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-2">
                <label class="text-xs" style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.1em;">
                    WHO CAN VIEW
                </label>
                <select asp-for="Input.ViewRole"
                        class="panel px-3 py-2 bg-transparent outline-none text-sm"
                        style="color: var(--color-crystal); font-family: var(--font-mono);">
                    <option value="">Default (@(Model.Settings.DefaultViewRole ?? "Public"))</option>
                    @foreach (var role in ShulkerTech.Core.Models.WikiSettings.RoleHierarchy)
                    {
                        <option value="@role" selected="@(Model.Input.ViewRole == role)">@role only</option>
                    }
                </select>
            </div>
            <div class="flex flex-col gap-2">
                <label class="text-xs" style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.1em;">
                    WHO CAN EDIT
                </label>
                <select asp-for="Input.EditRole"
                        class="panel px-3 py-2 bg-transparent outline-none text-sm"
                        style="color: var(--color-crystal); font-family: var(--font-mono);">
                    <option value="">Default (Permissions-based)</option>
                    @foreach (var role in ShulkerTech.Core.Models.WikiSettings.RoleHierarchy)
                    {
                        <option value="@role" selected="@(Model.Input.EditRole == role)">@role only</option>
                    }
                </select>
            </div>
        </div>

        <!-- Publish toggle -->
        <label class="flex items-center gap-3 cursor-pointer select-none">
            <input asp-for="Input.IsPublished" type="checkbox"
                   class="w-4 h-4" style="accent-color: var(--color-accent);" />
            <span class="text-xs" style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.1em;">
                PUBLISH IMMEDIATELY
            </span>
        </label>

        <!-- Actions -->
        <div class="flex items-center gap-4 pt-2">
            <button type="submit" class="btn-primary">SAVE ARTICLE</button>
            <a href="/" class="nav-link">CANCEL</a>
        </div>
    </form>

</div>

@section Head {
    <link rel="stylesheet" href="~/css/easymde.min.css" />
}

@section Scripts {
    <script src="~/js/easymde.min.js"></script>
    <script>
        // Tag picker
        (function () {
            var input = document.getElementById('tag-ids-input');
            var selected = new Set();
            document.querySelectorAll('[data-tag-id]').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var id = btn.dataset.tagId;
                    if (selected.has(id)) {
                        selected.delete(id);
                        btn.classList.remove('tag-pill--active');
                    } else {
                        selected.add(id);
                        btn.classList.add('tag-pill--active');
                    }
                    input.value = Array.from(selected).join(',');
                });
            });
        })();

        document.getElementById('title-input').addEventListener('input', function () {
            var slug = this.value.toLowerCase()
                .replace(/[^a-z0-9\s]/g, '')
                .trim()
                .replace(/\s+/g, '-');
            document.getElementById('slug-preview').textContent = slug || '—';
        });

        var _csrf = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') ?? '';
        var easyMDE = new EasyMDE({
            element: document.getElementById('content-editor'),
            spellChecker: false,
            autosave: { enabled: false },
            toolbar: [
                'bold', 'italic', 'heading', '|',
                'unordered-list', 'ordered-list', '|',
                'link', 'image', 'upload-image', '|',
                'preview', 'side-by-side', 'fullscreen', '|',
                'guide'
            ],
            imageUploadFunction: function (file, onSuccess, onError) {
                var fd = new FormData();
                fd.append('file', file);
                fetch('/api/wiki/upload-image', {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': _csrf },
                    body: fd
                })
                .then(function (r) {
                    return r.json().then(function (d) {
                        r.ok ? onSuccess(d.data.filePath) : onError(d.error ?? 'Upload failed');
                    });
                })
                .catch(function () { onError('Network error during upload'); });
            },
            imagePathAbsolute: true,
            status: ['upload-image', 'lines', 'words', 'cursor'],
        });

        // Template data from server
        var TEMPLATES = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.Templates.Select(t => new { t.Id, t.Name, t.Content, t.IsDefault }),
            new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));

        async function loadTemplate(tmpl) {
            var current = easyMDE.value().trim();
            if (current && !await siteConfirm('Replace current content with the "' + tmpl.name + '" template?')) return;
            easyMDE.value(tmpl.content);
            easyMDE.codemirror.focus();
        }

        // Wire up template buttons
        document.querySelectorAll('.template-load-btn').forEach(function (btn) {
            var id = parseInt(btn.dataset.templateId);
            var tmpl = TEMPLATES.find(function (t) { return t.id === id; });
            if (!tmpl) return;
            btn.addEventListener('click', function () { loadTemplate(tmpl); });
        });

        // Auto-load default template if editor is empty
        var defaultTmpl = TEMPLATES.find(function (t) { return t.isDefault; });
        if (defaultTmpl && !easyMDE.value().trim()) {
            easyMDE.value(defaultTmpl.content);
        }
    </script>
}
