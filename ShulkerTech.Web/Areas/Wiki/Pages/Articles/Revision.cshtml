@page "/Wiki/articles/revision/{id:int}"
@model RevisionModel
@using DiffPlex.DiffBuilder.Model
@{
    ViewData["Title"] = $"Revision — {Model.Revision.Title}";
}

<div class="px-4 sm:px-8 lg:px-16 xl:px-24 2xl:px-32 py-10">

    <!-- Header -->
    <div class="mb-8">
        <a href="/articles/history/@Model.Article.Id"
           style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-muted); letter-spacing: 0.08em; text-decoration: none;">
            ← REVISION HISTORY
        </a>
        <p class="text-xs tracking-widest mt-4 mb-2" style="font-family: var(--font-mono); color: var(--color-rune);">◆ ARCHIVED REVISION</p>
        <h1 style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; letter-spacing: 0.08em; color: var(--color-crystal);">
            @Model.Revision.Title.ToUpperInvariant()
        </h1>
        <div class="mt-3 flex flex-wrap items-center gap-4">
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted);">
                SAVED BY @((Model.Revision.Editor?.MinecraftUsername ?? Model.Revision.Editor?.UserName)?.ToUpperInvariant() ?? "UNKNOWN")
            </span>
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted);">
                @Model.Revision.EditedAt.ToString("MMM d, yyyy · HH:mm UTC").ToUpper()
            </span>
        </div>
    </div>

    <!-- Restore + compare bar -->
    <div class="panel p-4 mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4"
         style="border-color: color-mix(in oklab, var(--color-redstone) 40%, transparent);
                background: color-mix(in oklab, var(--color-redstone) 5%, transparent);">
        <p style="font-family: var(--font-mono); font-size: 0.8rem; color: var(--color-muted); letter-spacing: 0.04em;">
            Archived revision — live article may differ.
        </p>
        <form method="post" asp-page-handler="Restore">
            <button type="submit"
                    style="font-family: var(--font-display); font-size: 0.7rem; letter-spacing: 0.12em;
                           text-transform: uppercase; white-space: nowrap;
                           padding: 0.4rem 1rem; border-radius: 0.25rem; cursor: pointer;
                           background: color-mix(in oklab, var(--color-redstone) 15%, transparent);
                           color: var(--color-redstone);
                           border: 1px solid color-mix(in oklab, var(--color-redstone) 40%, transparent);
                           transition: background 150ms;">
                ↩ RESTORE THIS REVISION
            </button>
        </form>
    </div>

    <!-- Tab strip -->
    <div class="flex gap-1 mb-4" style="border-bottom: 1px solid color-mix(in oklab, var(--color-accent) 20%, transparent);">
        <a href="?compare=none"
           style="font-family: var(--font-display); font-size: 0.7rem; letter-spacing: 0.1em;
                  padding: 0.4rem 1rem; text-decoration: none; border-radius: 0.25rem 0.25rem 0 0;
                  @(Model.Compare == "none"
                    ? "background: color-mix(in oklab, var(--color-accent) 15%, transparent); color: var(--color-accent);"
                    : "color: var(--color-muted);")">
            CONTENT
        </a>
        <a href="?compare=current"
           style="font-family: var(--font-display); font-size: 0.7rem; letter-spacing: 0.1em;
                  padding: 0.4rem 1rem; text-decoration: none; border-radius: 0.25rem 0.25rem 0 0;
                  @(Model.Compare != "none"
                    ? "background: color-mix(in oklab, var(--color-accent) 15%, transparent); color: var(--color-accent);"
                    : "color: var(--color-muted);")">
            DIFF
        </a>
    </div>

    @if (Model.Compare == "none")
    {
        <!-- Plain content view -->
        <div class="panel wiki-content" style="padding: 2.5rem;">
            @Html.Raw(Model.ContentHtml)
        </div>
    }
    else
    {
        <!-- Diff view -->
        <div class="panel p-4 mb-4 flex flex-col sm:flex-row sm:items-center gap-4">
            <span style="font-family: var(--font-mono); font-size: 0.78rem; color: var(--color-muted); white-space: nowrap;">
                COMPARE WITH
            </span>
            <form method="get" class="flex-1">
                <select name="compare" onchange="this.form.submit()"
                        style="width: 100%; background: var(--color-deep-space); color: var(--color-crystal);
                               font-family: var(--font-mono); font-size: 0.8rem; padding: 0.35rem 0.6rem;
                               border: 1px solid color-mix(in oklab, var(--color-accent) 25%, transparent);
                               border-radius: 0.25rem; cursor: pointer;">
                    <option value="current" selected="@(Model.Compare == "current")">Current version</option>
                    @foreach (var sibling in Model.SiblingRevisions)
                    {
                        <option value="@sibling.Id" selected="@(Model.Compare == sibling.Id.ToString())">
                            @sibling.EditedAt.ToString("MMM d, yyyy · HH:mm") UTC
                        </option>
                    }
                </select>
            </form>
        </div>

        @if (!Model.DiffLines.Any())
        {
            <div class="panel p-8 text-center"
                 style="color: var(--color-muted); font-family: var(--font-mono); font-size: 0.85rem; letter-spacing: 0.06em;">
                NO DIFFERENCES — CONTENT IS IDENTICAL TO @Model.CompareLabel.ToUpperInvariant()
            </div>
        }
        else
        {
            <!-- Legend -->
            <div class="flex gap-6 mb-3 px-1">
                <span style="font-family: var(--font-mono); font-size: 0.72rem; color: #4ade80;">+ added in @Model.CompareLabel</span>
                <span style="font-family: var(--font-mono); font-size: 0.72rem; color: var(--color-redstone);">− in this revision only</span>
            </div>

            <div class="panel overflow-x-auto" style="padding: 0;">
                <pre style="margin: 0; font-family: var(--font-mono); font-size: 0.8rem; line-height: 1.6;">@foreach (var line in Model.DiffLines)
{
    if (line.SeparatorBefore)
    {
        <span style="display: block; padding: 0.15rem 1rem; color: var(--color-muted); background: color-mix(in oklab, var(--color-accent) 5%, transparent); border-top: 1px solid color-mix(in oklab, var(--color-accent) 10%, transparent); border-bottom: 1px solid color-mix(in oklab, var(--color-accent) 10%, transparent);">··· ···</span>
    }
    <span style="display: block; padding: 0.1rem 1rem; background: @line.Background; color: @line.Color; white-space: pre-wrap; word-break: break-word;">@line.Prefix@line.Piece.Text</span>
}</pre>
            </div>
        }
    }

</div>
