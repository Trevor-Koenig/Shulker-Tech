@page "/Admin/Security/Settings"
@model SettingsModel
@{
    ViewData["Title"] = "Security Settings";
}

<div class="px-6 lg:px-10 py-10">

    <div class="mb-8">
        <p class="text-xs tracking-widest mt-4 mb-2" style="font-family: var(--font-mono); color: var(--color-rune);">&#9670; SECURITY</p>
        <h1 style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; letter-spacing: 0.1em; color: var(--color-crystal);">
            SECURITY SETTINGS
        </h1>
        <p class="mt-2 text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">
            Users in selected roles will be redirected to set up two-factor authentication before they can access the site.
        </p>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="mb-6 px-4 py-3 rounded panel text-sm" style="color: var(--color-accent); font-family: var(--font-mono);">
            @Model.StatusMessage
        </div>
    }

    <form method="post" class="flex flex-col gap-6">
        @Html.AntiForgeryToken()

        <!-- Guest Role -->
        <div class="panel p-6 flex flex-col gap-4">
            <div>
                <h2 style="font-family: var(--font-display); font-size: 1rem; font-weight: 900; letter-spacing: 0.1em; color: var(--color-crystal);">
                    GUEST ROLE
                </h2>
                <p class="mt-2 text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">
                    Unauthenticated visitors are treated as if they hold this role for permission checks.
                    Assign permissions to the selected role to control what non-logged-in users can see.
                    Leave blank to rely on each resource's default visibility.
                </p>
            </div>
            <div class="flex items-center gap-3">
                <select name="GuestRole"
                        style="font-family: var(--font-mono); font-size: 0.85rem; color: var(--color-crystal); background: var(--color-surface); border: 1px solid color-mix(in oklab, var(--color-accent) 25%, transparent); border-radius: 0.375rem; padding: 0.5rem 0.75rem; min-width: 200px;">
                    <option value="">— None —</option>
                    @foreach (var role in Model.AllRoles)
                    {
                        if (Model.GuestRole.Equals(role, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@role" selected>@role</option>
                        }
                        else
                        {
                            <option value="@role">@role</option>
                        }
                    }
                </select>
            </div>
        </div>

        <!-- Require 2FA -->
        <div class="panel p-6 flex flex-col gap-4">
            <h2 style="font-family: var(--font-display); font-size: 1rem; font-weight: 900; letter-spacing: 0.1em; color: var(--color-crystal);">
                REQUIRE TWO-FACTOR AUTHENTICATION
            </h2>
            <p class="text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">
                Members of the selected roles must enable an authenticator app before accessing the site.
                New roles created on the Roles &amp; Permissions page appear here automatically.
            </p>
        </div>

        @if (Model.AllRoles.Count == 0)
        {
            <p class="text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">No roles defined yet.</p>
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                @foreach (var role in Model.AllRoles)
                {
                    var isChecked = Model.RequiredTwoFactorRoles.Contains(role, StringComparer.OrdinalIgnoreCase);
                    <label class="panel p-6 flex items-start gap-4 cursor-pointer">
                        <input type="checkbox"
                               name="RequiredTwoFactorRoles"
                               value="@role"
                               @(isChecked ? "checked" : "")
                               class="w-4 h-4 rounded mt-0.5 flex-shrink-0"
                               style="accent-color: var(--color-accent);" />
                        <div class="flex flex-col gap-1">
                            <span style="font-family: var(--font-display); font-size: 0.85rem; letter-spacing: 0.08em; color: var(--color-crystal);">@role.ToUpperInvariant()</span>
                            <span class="text-xs" style="color: var(--color-muted); font-family: var(--font-mono); line-height: 1.5;">
                                Require 2FA for all @role accounts.
                            </span>
                        </div>
                    </label>
                }
            </div>
        }

        <div>
            <button type="submit" class="btn-primary">SAVE SETTINGS</button>
        </div>

    </form>
</div>
