@page
@model IndexModel
@{
    ViewData["Title"] = "Map Servers";
}

<div class="max-w-5xl px-8 py-12">

    <div class="mb-8">
        <p class="text-xs tracking-widest mt-4 mb-2" style="font-family: var(--font-mono); color: var(--color-rune);">&#9670; MAPS</p>
        <h1 style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; letter-spacing: 0.1em; color: var(--color-crystal);">
            MAP SERVERS
        </h1>
        <p class="mt-2 text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">
            @Model.MapServers.Count configured &nbsp;·&nbsp; @Model.MapServers.Count(m => m.IsActive) shown on homepage
        </p>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="mb-6 px-4 py-3 rounded panel text-sm" style="color: var(--color-accent); font-family: var(--font-mono);">
            @Model.StatusMessage
        </div>
    }

    @* Add form *@
    <div class="panel p-6 mb-8">
        <h2 class="text-sm mb-4" style="font-family: var(--font-display); color: var(--color-crystal); letter-spacing: 0.08em;">
            ADD MAP SERVER
        </h2>
        <form method="post" asp-page-handler="Add" class="flex flex-col sm:flex-row gap-3">
            <input asp-for="Input.Label" placeholder="Label (e.g. Main SMP)"
                   class="flex-none sm:w-40 px-3 py-2 rounded text-sm"
                   style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent); color: var(--color-crystal);" />
            <input asp-for="Input.Url" placeholder="https://map.example.com"
                   class="flex-1 px-3 py-2 rounded text-sm"
                   style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent); color: var(--color-crystal);" />
            <button type="submit" class="btn-primary px-4 py-2 text-sm">ADD</button>
        </form>
        <span asp-validation-for="Input.Url" class="text-xs mt-1 block" style="color: var(--color-rune);"></span>
    </div>

    @* Server list *@
    <div class="flex flex-col gap-3">
        @foreach (var map in Model.MapServers)
        {
            <div class="panel p-4 flex flex-col sm:flex-row sm:items-center gap-3">
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold" style="color: var(--color-crystal); font-family: var(--font-display); letter-spacing: 0.05em;">
                        @map.Label
                    </p>
                    <p class="text-xs truncate mt-1" style="color: var(--color-muted); font-family: var(--font-mono);">
                        @map.Url
                    </p>
                </div>
                <div class="flex items-center gap-2 flex-none">
                    <form method="post" asp-page-handler="Toggle">
                        <input type="hidden" name="id" value="@map.Id" />
                        <button type="submit" class="px-3 py-1 rounded text-xs" style="font-family: var(--font-display); letter-spacing: 0.05em;
                            background: @(map.IsActive ? "color-mix(in oklab, var(--color-accent) 15%, transparent)" : "color-mix(in oklab, var(--color-muted) 10%, transparent)");
                            color: @(map.IsActive ? "var(--color-accent)" : "var(--color-muted)");
                            border: 1px solid @(map.IsActive ? "color-mix(in oklab, var(--color-accent) 40%, transparent)" : "color-mix(in oklab, var(--color-muted) 20%, transparent)");">
                            @(map.IsActive ? "ACTIVE" : "INACTIVE")
                        </button>
                    </form>
                    <form method="post" asp-page-handler="Delete">
                        <input type="hidden" name="id" value="@map.Id" />
                        <button type="submit" class="px-3 py-1 rounded text-xs"
                                style="font-family: var(--font-display); letter-spacing: 0.05em; color: var(--color-rune); border: 1px solid color-mix(in oklab, var(--color-rune) 30%, transparent);">
                            REMOVE
                        </button>
                    </form>
                </div>
            </div>
        }

        @if (!Model.MapServers.Any())
        {
            <p class="text-center py-8 text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">
                No map servers configured. Add one above.
            </p>
        }
    </div>
</div>
