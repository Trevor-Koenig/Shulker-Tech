@page
@model IndexModel
@{
    ViewData["Title"] = "Users";
}

<div class="max-w-5xl px-8 py-12">

    <div class="mb-8">
        <p class="text-xs tracking-widest mt-4 mb-2" style="font-family: var(--font-mono); color: var(--color-rune);">&#9670; USERS</p>
        <h1 style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; letter-spacing: 0.1em; color: var(--color-crystal);">
            MEMBERS
        </h1>
    </div>

    <div class="flex flex-col gap-3">
        @foreach (var row in Model.Users)
        {
            <div class="panel p-4 flex flex-col sm:flex-row sm:items-center gap-3">
                <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-3 flex-wrap">
                        <span class="text-sm font-bold" style="font-family: var(--font-mono); color: var(--color-crystal);">
                            @row.User.UserName
                        </span>
                        @if (row.User.IsAdmin)
                        {
                            <span class="text-xs px-2 py-0.5 rounded" style="font-family: var(--font-mono); color: var(--color-accent); border: 1px solid var(--color-accent);">OWNER</span>
                        }
                        @foreach (var role in row.Roles)
                        {
                            <span class="text-xs px-2 py-0.5 rounded" style="font-family: var(--font-mono); color: var(--color-arcane); border: 1px solid color-mix(in oklab, var(--color-arcane) 40%, transparent);">
                                @role.ToUpper()
                            </span>
                        }
                    </div>
                    <div class="mt-1 text-xs" style="color: var(--color-muted); font-family: var(--font-mono);">
                        @if (!string.IsNullOrEmpty(row.User.MinecraftUsername))
                        {
                            <span>@row.User.MinecraftUsername &nbsp;&bull;&nbsp;</span>
                        }
                        <span>joined @row.User.CreatedAt.ToString("yyyy-MM-dd")</span>
                    </div>
                </div>
                <a asp-page="Edit" asp-route-id="@row.User.Id"
                   class="px-3 py-1 rounded text-xs flex-none"
                   style="font-family: var(--font-display); letter-spacing: 0.05em; color: var(--color-accent); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent);">
                    MANAGE
                </a>
            </div>
        }

        @if (!Model.Users.Any())
        {
            <p class="text-center py-8 text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">
                No users found.
            </p>
        }
    </div>
</div>
