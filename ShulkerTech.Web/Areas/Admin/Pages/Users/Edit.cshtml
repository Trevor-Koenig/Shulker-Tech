@page "{id}"
@model EditModel
@{
    ViewData["Title"] = $"User — {Model.Member?.UserName}";
}

<div class="px-6 lg:px-10 py-10">

    <div class="mb-8">
        <a asp-page="Index" class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted); letter-spacing: 0.08em; text-decoration: none;">← USERS</a>
        <p class="text-xs tracking-widest mt-4 mb-2" style="font-family: var(--font-mono); color: var(--color-rune);">&#9670; USERS</p>
        <h1 style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; letter-spacing: 0.1em; color: var(--color-crystal);">
            @Model.Member!.UserName?.ToUpper()
        </h1>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="mb-6 px-4 py-3 rounded panel text-sm" style="color: var(--color-accent); font-family: var(--font-mono);">
            @Model.StatusMessage
        </div>
    }

    <div class="lg:grid lg:grid-cols-2 lg:gap-6 lg:items-start">

    @* Left column: account info + account status *@
    <div class="flex flex-col gap-6 mb-6 lg:mb-0">

    @* User info *@
    <div class="panel p-6">
        <h2 class="text-xs mb-4" style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">ACCOUNT</h2>
        <dl class="flex flex-col gap-2 text-sm" style="font-family: var(--font-mono);">
            <div class="flex gap-4">
                <dt style="color: var(--color-muted); min-width: 8rem;">Email</dt>
                <dd style="color: var(--color-crystal);">@Model.Member.Email</dd>
            </div>
            @if (!string.IsNullOrEmpty(Model.Member.MinecraftUsername))
            {
                <div class="flex gap-4">
                    <dt style="color: var(--color-muted); min-width: 8rem;">Minecraft</dt>
                    <dd style="color: var(--color-crystal);">@Model.Member.MinecraftUsername</dd>
                </div>
            }
            <div class="flex gap-4">
                <dt style="color: var(--color-muted); min-width: 8rem;">Joined</dt>
                <dd style="color: var(--color-crystal);">@Model.Member.CreatedAt.ToString("yyyy-MM-dd")</dd>
            </div>
            <div class="flex gap-4">
                <dt style="color: var(--color-muted); min-width: 8rem;">Owner</dt>
                <dd style="color: var(--color-crystal);">@(Model.Member.IsAdmin ? "Yes" : "No")</dd>
            </div>
            <div class="flex gap-4">
                <dt style="color: var(--color-muted); min-width: 8rem;">Status</dt>
                <dd style="color: @(Model.IsDeactivated ? "var(--color-rune)" : "var(--color-arcane)");">
                    @(Model.IsDeactivated ? "DEACTIVATED" : "ACTIVE")
                </dd>
            </div>
        </dl>
    </div>

    @* Account status *@
    <div class="panel p-6">
        <h2 class="text-xs mb-4" style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">ACCOUNT STATUS</h2>

        @if (Model.IsDeactivated)
        {
            <div class="text-xs p-3 rounded mb-4" style="font-family: var(--font-mono); line-height: 1.6;
                        color: var(--color-rune);
                        background: color-mix(in oklab, var(--color-rune) 10%, transparent);
                        border: 1px solid color-mix(in oklab, var(--color-rune) 30%, transparent);">
                This account is deactivated. The user cannot sign in.
            </div>
            <form method="post" asp-page-handler="Reactivate" asp-route-id="@Model.Member.Id">
                <button type="submit" class="px-4 py-2 rounded text-xs"
                        style="font-family: var(--font-display); letter-spacing: 0.06em; cursor: pointer;
                               color: var(--color-arcane); border: 1px solid color-mix(in oklab, var(--color-arcane) 40%, transparent);
                               background: color-mix(in oklab, var(--color-arcane) 8%, transparent);">
                    REACTIVATE ACCOUNT
                </button>
            </form>
        }
        else
        {
            <p class="text-xs mb-4" style="font-family: var(--font-mono); color: var(--color-muted); line-height: 1.6;">
                Deactivating this account will immediately prevent the user from signing in.
            </p>
            <form method="post" asp-page-handler="Deactivate" asp-route-id="@Model.Member.Id">
                <button type="submit" class="px-4 py-2 rounded text-xs"
                        style="font-family: var(--font-display); letter-spacing: 0.06em; cursor: pointer;
                               color: var(--color-rune); border: 1px solid color-mix(in oklab, var(--color-rune) 40%, transparent);
                               background: color-mix(in oklab, var(--color-rune) 8%, transparent);">
                    DEACTIVATE ACCOUNT
                </button>
            </form>
        }
    </div>

    </div> @* end left column *@

    @* Right column: role assignment *@
    <div class="panel p-6">
        <h2 class="text-xs mb-4" style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">ROLES</h2>

        <div class="flex flex-col gap-3">
            @foreach (var role in Model.AllRoles)
            {
                var assigned = Model.AssignedRoles.Contains(role);
                <div class="flex items-center justify-between py-2"
                     style="border-bottom: 1px solid color-mix(in oklab, var(--color-arcane) 10%, transparent);">
                    <div class="flex items-center gap-3">
                        <span class="text-sm" style="font-family: var(--font-mono); color: var(--color-crystal);">@role</span>
                        @if (assigned)
                        {
                            <span class="text-xs px-2 py-0.5 rounded" style="font-family: var(--font-mono); color: var(--color-accent); border: 1px solid color-mix(in oklab, var(--color-accent) 40%, transparent);">ASSIGNED</span>
                        }
                    </div>
                    @if (assigned)
                    {
                        <form method="post" asp-page-handler="Remove" asp-route-id="@Model.Member.Id">
                            <input type="hidden" name="role" value="@role" />
                            <button type="submit" class="px-3 py-1 rounded text-xs"
                                    style="font-family: var(--font-display); letter-spacing: 0.05em; color: var(--color-rune); border: 1px solid color-mix(in oklab, var(--color-rune) 30%, transparent);">
                                REMOVE
                            </button>
                        </form>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="Assign" asp-route-id="@Model.Member.Id">
                            <input type="hidden" name="role" value="@role" />
                            <button type="submit" class="px-3 py-1 rounded text-xs"
                                    style="font-family: var(--font-display); letter-spacing: 0.05em; color: var(--color-arcane); border: 1px solid color-mix(in oklab, var(--color-arcane) 30%, transparent);">
                                ASSIGN
                            </button>
                        </form>
                    }
                </div>
            }
        </div>
    </div>

    </div> @* end lg:grid *@
</div>
