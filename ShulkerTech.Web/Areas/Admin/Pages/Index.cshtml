@page
@using ShulkerTech.Core.Models
@model IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";

    bool Can(string resource) => Model.AccessibleResources.Contains(resource);

    // Locked cards lose the href (Razor drops null attributes), get pointer-events: none,
    // and their footer label flips from "OPEN →" to "NO ACCESS".
    const string LockedStyle = "opacity: 0.4; pointer-events: none; cursor: default;";
}

<div class="px-6 lg:px-10 py-10">

    <div class="mb-10">
        <p class="text-xs tracking-widest mb-2" style="font-family: var(--font-mono); color: var(--color-rune);">&#9670; CONTROL CENTER</p>
        <h1 style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; letter-spacing: 0.1em; color: var(--color-crystal);">
            ADMIN DASHBOARD
        </h1>
        <p class="mt-2 text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">
            Signed in as @User.Identity?.Name
        </p>
    </div>

    @* Stats row *@
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-10">

        <div class="panel p-5 flex flex-col gap-1">
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted); letter-spacing: 0.08em;">USERS</span>
            <span style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--color-accent);">@Model.TotalUsers</span>
        </div>

        <div class="panel p-5 flex flex-col gap-1">
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted); letter-spacing: 0.08em;">ACTIVE INVITES</span>
            <span style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--color-accent);">@Model.ActiveInviteCodes</span>
        </div>

        <div class="panel p-5 flex flex-col gap-1">
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted); letter-spacing: 0.08em;">GAME SERVERS</span>
            <span style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--color-accent);">@Model.GameServers</span>
        </div>

        <div class="panel p-5 flex flex-col gap-1">
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted); letter-spacing: 0.08em;">ONLINE NOW</span>
            <span style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--color-accent);">@Model.ActiveSessions</span>
        </div>

        <div class="panel p-5 flex flex-col gap-1">
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted); letter-spacing: 0.08em;">MAP SERVERS</span>
            <span style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--color-accent);">@Model.TotalMapServers</span>
        </div>

        <div class="panel p-5 flex flex-col gap-1">
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted); letter-spacing: 0.08em;">MAPS ACTIVE</span>
            <span style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--color-accent);">@Model.ActiveMapServers</span>
        </div>

    </div>

    @* Nav cards *@
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

        @{
            // Each card: (label, description, url, resource)
            var cards = new (string Label, string Desc, string Url, string Resource)[]
            {
                ("&#9670; USERS",             "Manage accounts, assign roles, and review members.",                                        "/Admin/Users",             SiteResource.AdminUsers),
                ("&#9670; ROLES &amp; PERMISSIONS", "Create and delete roles, then control which actions each role can perform.",           "/Admin/Roles",             SiteResource.AdminRoles),
                ("&#9670; INVITES",            "Generate and revoke invite codes to control who can register.",                             "/Admin/Invites",           SiteResource.AdminInvites),
                ("&#9670; GAME SERVERS",       "Manage game servers and API keys for playtime tracking.",                                   "/Admin/Servers",           SiteResource.AdminServers),
                ("&#9670; MAP SERVERS",        "Configure and toggle the live map server integrations.",                                    "/Admin/Maps",              SiteResource.AdminMaps),
                ("&#9670; WIKI",               "Configure who can view, create, and edit wiki articles.",                                   "/Admin/Wiki/Settings",     SiteResource.AdminWikiSettings),
                ("&#9670; WIKI TAGS",          "Create, edit, and delete tags used to categorise wiki articles.",                           "/Admin/Wiki/Tags",         SiteResource.AdminWikiTags),
                ("&#9670; ARTICLE TEMPLATES",  "Manage Markdown templates that members can pick when creating new articles.",               "/Admin/Wiki/Templates",    SiteResource.AdminWikiTemplates),
                ("&#9670; SITE",               "Edit the homepage hero tagline and about section card text.",                               "/Admin/Site/Settings",     SiteResource.AdminSiteSettings),
                ("&#9670; SECURITY",           "Configure which roles are required to use two-factor authentication.",                      "/Admin/Security/Settings", SiteResource.AdminSecurity),
                ("&#9670; DATABASE EXPORT",    "Download a full gzip-compressed SQL dump of the database.",                                 "/Admin/Site/DbExport",     SiteResource.AdminDbExport),
            };
        }

        @foreach (var (label, desc, url, resource) in cards)
        {
            bool accessible = Can(resource);
            <a href="@(accessible ? url : null)"
               class="panel p-6 flex flex-col gap-3 @(accessible ? "group" : "")"
               style="text-decoration: none; @(!accessible ? LockedStyle : "")"
               aria-disabled="@(!accessible ? "true" : null)"
               tabindex="@(!accessible ? "-1" : null)">
                <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-rune); letter-spacing: 0.1em;">@Html.Raw(label)</span>
                <p class="text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">@desc</p>
                <span class="text-xs mt-auto" style="font-family: var(--font-display); letter-spacing: 0.08em;
                    color: @(accessible ? "var(--color-accent)" : "var(--color-muted)");">
                    @(accessible ? "OPEN →" : "NO ACCESS")
                </span>
            </a>
        }

    </div>
</div>
