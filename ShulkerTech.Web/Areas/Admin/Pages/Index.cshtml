@page
@model IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="px-6 lg:px-10 py-10">

    <div class="mb-10">
        <p class="text-xs tracking-widest mb-2" style="font-family: var(--font-mono); color: var(--color-rune);">&#9670; CONTROL CENTER</p>
        <h1 style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; letter-spacing: 0.1em; color: var(--color-crystal);">
            ADMIN DASHBOARD
        </h1>
        <p class="mt-2 text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">
            Signed in as @User.Identity?.Name
        </p>
    </div>

    @* Stats row *@
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-10">

        <div class="panel p-5 flex flex-col gap-1">
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted); letter-spacing: 0.08em;">USERS</span>
            <span style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--color-accent);">@Model.TotalUsers</span>
        </div>

        <div class="panel p-5 flex flex-col gap-1">
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted); letter-spacing: 0.08em;">ACTIVE INVITES</span>
            <span style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--color-accent);">@Model.ActiveInviteCodes</span>
        </div>

        <div class="panel p-5 flex flex-col gap-1">
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted); letter-spacing: 0.08em;">GAME SERVERS</span>
            <span style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--color-accent);">@Model.GameServers</span>
        </div>

        <div class="panel p-5 flex flex-col gap-1">
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted); letter-spacing: 0.08em;">ONLINE NOW</span>
            <span style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--color-accent);">@Model.ActiveSessions</span>
        </div>

        <div class="panel p-5 flex flex-col gap-1">
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted); letter-spacing: 0.08em;">MAP SERVERS</span>
            <span style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--color-accent);">@Model.TotalMapServers</span>
        </div>

        <div class="panel p-5 flex flex-col gap-1">
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted); letter-spacing: 0.08em;">MAPS ACTIVE</span>
            <span style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--color-accent);">@Model.ActiveMapServers</span>
        </div>

    </div>

    @* Nav cards *@
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

        <a asp-page="/Users/Index" class="panel p-6 flex flex-col gap-3 group" style="text-decoration: none;">
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-rune); letter-spacing: 0.1em;">&#9670; USERS</span>
            <p class="text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">
                Manage accounts, assign roles, and review members.
            </p>
            <span class="text-xs mt-auto" style="font-family: var(--font-display); color: var(--color-accent); letter-spacing: 0.08em;">OPEN →</span>
        </a>

        <a asp-page="/Invites/Index" class="panel p-6 flex flex-col gap-3 group" style="text-decoration: none;">
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-rune); letter-spacing: 0.1em;">&#9670; INVITES</span>
            <p class="text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">
                Generate and revoke invite codes to control who can register.
            </p>
            <span class="text-xs mt-auto" style="font-family: var(--font-display); color: var(--color-accent); letter-spacing: 0.08em;">OPEN →</span>
        </a>

        <a asp-page="/Servers/Index" class="panel p-6 flex flex-col gap-3 group" style="text-decoration: none;">
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-rune); letter-spacing: 0.1em;">&#9670; GAME SERVERS</span>
            <p class="text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">
                Manage game servers and API keys for playtime tracking.
            </p>
            <span class="text-xs mt-auto" style="font-family: var(--font-display); color: var(--color-accent); letter-spacing: 0.08em;">OPEN →</span>
        </a>

        <a asp-page="/Maps/Index" class="panel p-6 flex flex-col gap-3 group" style="text-decoration: none;">
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-rune); letter-spacing: 0.1em;">&#9670; MAP SERVERS</span>
            <p class="text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">
                Configure and toggle the live map server integrations.
            </p>
            <span class="text-xs mt-auto" style="font-family: var(--font-display); color: var(--color-accent); letter-spacing: 0.08em;">OPEN →</span>
        </a>

        <a asp-page="/Wiki/Settings" class="panel p-6 flex flex-col gap-3 group" style="text-decoration: none;">
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-rune); letter-spacing: 0.1em;">&#9670; WIKI</span>
            <p class="text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">
                Configure who can view, create, and edit wiki articles.
            </p>
            <span class="text-xs mt-auto" style="font-family: var(--font-display); color: var(--color-accent); letter-spacing: 0.08em;">OPEN →</span>
        </a>

        <a asp-page="/Site/Settings" class="panel p-6 flex flex-col gap-3 group" style="text-decoration: none;">
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-rune); letter-spacing: 0.1em;">&#9670; SITE</span>
            <p class="text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">
                Edit the homepage hero tagline and about section card text.
            </p>
            <span class="text-xs mt-auto" style="font-family: var(--font-display); color: var(--color-accent); letter-spacing: 0.08em;">OPEN →</span>
        </a>

        <a asp-page="/Security/Settings" class="panel p-6 flex flex-col gap-3 group" style="text-decoration: none;">
            <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-rune); letter-spacing: 0.1em;">&#9670; SECURITY</span>
            <p class="text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">
                Configure which roles are required to use two-factor authentication.
            </p>
            <span class="text-xs mt-auto" style="font-family: var(--font-display); color: var(--color-accent); letter-spacing: 0.08em;">OPEN →</span>
        </a>

    </div>
</div>
