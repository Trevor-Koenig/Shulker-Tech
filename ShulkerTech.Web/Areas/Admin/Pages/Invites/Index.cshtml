@page
@model IndexModel
@{
    ViewData["Title"] = "Invite Codes";
}

<div class="px-6 lg:px-10 py-10">

    <div class="mb-8">
        <p class="text-xs tracking-widest mt-4 mb-2" style="font-family: var(--font-mono); color: var(--color-rune);">&#9670; INVITES</p>
        <h1 style="font-family: var(--font-display); font-size: 2rem; font-weight: 900; letter-spacing: 0.1em; color: var(--color-crystal);">
            INVITE CODES
        </h1>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="mb-6 px-4 py-3 rounded panel text-sm" style="color: var(--color-accent); font-family: var(--font-mono);">
            @Model.StatusMessage
        </div>
    }

    @* Generate form *@
    <div class="panel p-6 mb-8">
        <h2 class="text-sm mb-4" style="font-family: var(--font-display); color: var(--color-crystal); letter-spacing: 0.08em;">
            GENERATE CODE
        </h2>
        <form id="generate-form" method="post" asp-page-handler="Generate" class="flex flex-col sm:flex-row gap-3 flex-wrap">
            <input asp-for="Input.Note" placeholder="Note (e.g. Wave 3 - Discord)"
                   class="flex-1 px-3 py-2 rounded text-sm"
                   style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent); color: var(--color-crystal);" />
            <div class="flex items-center gap-2">
                <label class="text-xs whitespace-nowrap" style="color: var(--color-muted); font-family: var(--font-mono);">MAX USES</label>
                <input asp-for="Input.MaxUses" type="number" min="1" max="100"
                       class="w-20 px-3 py-2 rounded text-sm text-center"
                       style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent); color: var(--color-crystal);" />
            </div>
            <div class="flex items-center gap-2">
                <label class="text-xs whitespace-nowrap" style="color: var(--color-muted); font-family: var(--font-mono);">EXPIRES</label>
                <input type="datetime-local" id="expires-local"
                       class="px-3 py-2 rounded text-sm"
                       style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent); color: var(--color-crystal);" />
                <input type="hidden" name="Input.ExpiresAt" id="expires-utc" />
            </div>
            <button type="submit" class="btn-primary px-6 py-2 text-sm whitespace-nowrap">GENERATE</button>
        </form>
    </div>

    @* Code list *@
    <div class="flex flex-col gap-3">
        @foreach (var code in Model.Codes)
        {
            var isExpired = code.ExpiresAt.HasValue && code.ExpiresAt < DateTime.UtcNow;
            var isExhausted = code.UseCount >= code.MaxUses;
            var statusColor = code.IsRevoked ? "var(--color-rune)"
                            : isExpired || isExhausted ? "var(--color-muted)"
                            : "var(--color-accent)";
            var statusLabel = code.IsRevoked ? "REVOKED"
                            : isExpired ? "EXPIRED"
                            : isExhausted ? "EXHAUSTED"
                            : "ACTIVE";

            <div class="panel p-4 flex flex-col sm:flex-row sm:items-center gap-3">
                <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-3 flex-wrap">
                        <code class="text-sm font-bold" style="font-family: var(--font-mono); color: var(--color-crystal); letter-spacing: 0.1em;">
                            @code.Code
                        </code>
                        <span class="text-xs px-2 py-0.5 rounded" style="font-family: var(--font-mono); color: @statusColor; border: 1px solid @statusColor; opacity: 0.9;">
                            @statusLabel
                        </span>
                    </div>
                    <div class="flex gap-4 mt-1 text-xs flex-wrap" style="color: var(--color-muted); font-family: var(--font-mono);">
                        <span>@code.UseCount / @code.MaxUses uses</span>
                        @if (!string.IsNullOrEmpty(code.Note))
                        {
                            <span>@code.Note</span>
                        }
                        @if (code.ExpiresAt.HasValue)
                        {
                            <span>expires <time class="local-datetime" datetime="@code.ExpiresAt.Value.ToUniversalTime().ToString("O")">@code.ExpiresAt.Value.ToUniversalTime().ToString("yyyy-MM-dd HH:mm") UTC</time></span>
                        }
                        <span>created <time class="local-datetime" datetime="@code.CreatedAt.ToUniversalTime().ToString("O")">@code.CreatedAt.ToUniversalTime().ToString("yyyy-MM-dd HH:mm") UTC</time></span>
                    </div>
                </div>
                @if (!code.IsRevoked)
                {
                    <div class="flex gap-2 flex-none">
                        <button type="button" onclick="copyInviteLink('@code.Code', this)"
                                class="px-3 py-1 rounded text-xs"
                                style="font-family: var(--font-display); letter-spacing: 0.05em; color: var(--color-arcane); border: 1px solid color-mix(in oklab, var(--color-arcane) 30%, transparent);">
                            COPY LINK
                        </button>
                        <form method="post" asp-page-handler="Revoke">
                            <input type="hidden" name="id" value="@code.Id" />
                            <button type="submit" class="px-3 py-1 rounded text-xs"
                                    style="font-family: var(--font-display); letter-spacing: 0.05em; color: var(--color-rune); border: 1px solid color-mix(in oklab, var(--color-rune) 30%, transparent);">
                                REVOKE
                            </button>
                        </form>
                    </div>
                }
            </div>
        }

        @if (!Model.Codes.Any())
        {
            <p class="text-center py-8 text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">
                No invite codes yet. Generate one above.
            </p>
        }
    </div>
</div>

@section Scripts {
    <script>
    document.getElementById('generate-form').addEventListener('submit', function () {
        var local = document.getElementById('expires-local').value;
        if (local) {
            // datetime-local value is treated as local time by Date(); convert to UTC ISO string
            document.getElementById('expires-utc').value = new Date(local).toISOString();
        }
    });

    function copyInviteLink(code, btn) {
        var url = '@Url.Page("/Account/Register", null, new { area = "Identity" }, HttpContext.Request.Scheme)'
                + '?code=' + encodeURIComponent(code);
        navigator.clipboard.writeText(url).then(function () {
            var orig = btn.textContent;
            btn.textContent = 'COPIED';
            setTimeout(function () { btn.textContent = orig; }, 1500);
        });
    }

    document.querySelectorAll('time.local-datetime').forEach(function (el) {
        var d = new Date(el.getAttribute('datetime'));
        el.textContent = d.toLocaleString(undefined, {
            year: 'numeric', month: '2-digit', day: '2-digit',
            hour: '2-digit', minute: '2-digit'
        });
    });
    </script>
}
