@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<section class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-32 text-center">

    <p class="mb-4 tracking-widest"
       style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-rune); letter-spacing: 0.15em;">
        &#9670; SERVER ERROR
    </p>

    <h1 class="mb-6"
        style="font-family: var(--font-fantasy); font-size: clamp(3rem, 10vw, 6rem);
               color: var(--color-redstone); text-shadow: 0 0 40px color-mix(in oklab, var(--color-redstone) 50%, transparent);">
        500
    </h1>

    <p class="mb-4" style="font-family: var(--font-display); font-size: 1.1rem; color: var(--color-crystal); letter-spacing: 0.06em;">
        Something went wrong on our end.
    </p>

    <p class="mb-10 text-sm" style="font-family: var(--font-mono); color: var(--color-muted);">
        The server encountered an unexpected error. Try again in a moment.
    </p>

    @if (Model.ShowRequestId)
    {
        <p class="mb-10 text-xs" style="font-family: var(--font-mono); color: var(--color-muted);">
            Request ID: <span style="color: var(--color-rune);">@Model.RequestId</span>
        </p>
    }

    <a href="/" class="btn-primary px-8 py-3">RETURN HOME</a>

</section>
