@page "/404"
@model NotFoundModel
@{
    ViewData["Title"] = "404 — Not Found";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="flex flex-col items-center justify-center text-center px-4" style="min-height: 60vh;">

    <!-- Glitch code -->
    <p class="text-xs tracking-widest mb-4" style="font-family: var(--font-mono); color: var(--color-redstone); letter-spacing: 0.2em;">
        ERROR :: 0x404
    </p>

    <!-- Big 404 -->
    <div style="font-family: var(--font-display); font-size: clamp(5rem, 20vw, 10rem); font-weight: 900; line-height: 1;
                color: transparent;
                -webkit-text-stroke: 2px color-mix(in oklab, var(--color-accent) 40%, transparent);
                text-shadow: 0 0 60px color-mix(in oklab, var(--color-accent) 15%, transparent);">
        404
    </div>

    <!-- Flavour text -->
    <h1 class="mt-4 mb-2" style="font-family: var(--font-display); font-size: 1.4rem; font-weight: 900; letter-spacing: 0.12em; color: var(--color-crystal);">
        YOU FELL INTO THE VOID
    </h1>
    <p style="font-family: var(--font-mono); font-size: 0.85rem; color: var(--color-muted); max-width: 28rem; line-height: 1.7;">
        This chunk hasn't been generated. The block you're looking for doesn't exist,
        or was moved to another dimension.
    </p>

    <!-- Divider -->
    <div class="rune-divider w-48 my-8">&#9670;</div>

    <!-- Actions -->
    <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/" class="btn-primary">RETURN HOME</a>
        <a href="javascript:history.back()" class="nav-link">← GO BACK</a>
    </div>

</div>
