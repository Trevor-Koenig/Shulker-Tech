@using Microsoft.AspNetCore.Identity
@using ShulkerTech.Core.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    var _currentUser = await UserManager.GetUserAsync(User);
    if (_currentUser?.IsAdmin == true)
    {
        var _host = Context.Request.Host.Host;
        var _firstSegment = _host.Split('.')[0];
        string[] _knownSubdomains = ["wiki", "admin"];
        var _rootHost = _knownSubdomains.Contains(_firstSegment, StringComparer.OrdinalIgnoreCase)
            ? _host[(_firstSegment.Length + 1)..]
            : _host;
        var _port = Context.Request.Host.Port;
        var _adminBase = $"{Context.Request.Scheme}://admin.{_rootHost}{(_port.HasValue ? $":{_port}" : "")}";
    }

    <!-- Desktop: separator then settings dropdown -->
    <li aria-hidden="true" class="nav-separator hidden sm:flex"></li>
    <li class="hidden sm:flex" style="position: relative;">
        <button id="settings-btn" class="nav-user flex items-center gap-1"
                aria-expanded="false" aria-haspopup="true"
                style="background: none; border: none; cursor: pointer; padding: 0;">
            @User.Identity?.Name
            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2.5"
                 stroke-linecap="round" stroke-linejoin="round"
                 style="opacity: 0.6; margin-top: 1px;">
                <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
        </button>
        <div id="settings-dropdown" class="hidden nav-dropdown panel">
            <a asp-area="Identity" asp-page="/Account/Manage/Index" class="nav-dropdown-item">Account</a>
            <div class="nav-dropdown-divider"></div>
            <button data-theme-toggle class="nav-dropdown-item">◈ Arcane Mode</button>
            <div class="nav-dropdown-divider"></div>
            <a asp-area="Identity" asp-page="/Account/Logout" class="nav-dropdown-item"
               style="color: color-mix(in oklab, var(--color-redstone) 70%, var(--color-muted));">Sign Out</a>
        </div>
    </li>

    <!-- Mobile: flat links -->
    <div class="sm:hidden" style="height: 1px; background: color-mix(in oklab, var(--color-accent) 15%, transparent);"></div>
    <a asp-area="Identity" asp-page="/Account/Manage/Index" class="nav-user sm:hidden">@User.Identity?.Name</a>
    <a asp-area="Identity" asp-page="/Account/Manage/Index" class="nav-link sm:hidden">ACCOUNT</a>
    <button data-theme-toggle class="nav-link sm:hidden" style="background: none; border: none; cursor: pointer; padding: 0; text-align: left;">◈ Arcane Mode</button>
    <a asp-area="Identity" asp-page="/Account/Logout" class="nav-link sm:hidden" style="color: color-mix(in oklab, var(--color-redstone) 70%, var(--color-muted));">SIGN OUT</a>
}
else
{
    <!-- Desktop: separator, sign in, enlist button -->
    <li aria-hidden="true" class="nav-separator hidden sm:flex"></li>
    <li class="hidden sm:flex"><a class="nav-link" asp-area="Identity" asp-page="/Account/Login">SIGN IN</a></li>
    <li class="hidden sm:flex"><a class="btn-nav" asp-area="Identity" asp-page="/Account/Register">ENLIST</a></li>

    <!-- Mobile -->
    <div class="sm:hidden" style="height: 1px; background: color-mix(in oklab, var(--color-accent) 15%, transparent);"></div>
    <a class="nav-link sm:hidden" asp-area="Identity" asp-page="/Account/Login">SIGN IN</a>
    <a class="btn-nav sm:hidden" asp-area="Identity" asp-page="/Account/Register">ENLIST</a>
    <button data-theme-toggle class="nav-link sm:hidden" style="background: none; border: none; cursor: pointer; padding: 0; text-align: left;">◈ Arcane Mode</button>
}
