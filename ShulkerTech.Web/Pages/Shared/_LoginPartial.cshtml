@using Microsoft.AspNetCore.Identity
@using ShulkerTech.Core.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index", new { area = "" })" method="post">
        <span class="nav-link" style="color: var(--color-plasma); font-family: var(--font-mono); font-size: 0.7rem;">
            @User.Identity?.Name
        </span>
        <button type="submit" class="nav-link">SIGN OUT</button>
    </form>
}
else
{
    <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">ENLIST</a>
    <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">SIGN IN</a>
}
