@using Microsoft.AspNetCore.Identity
@using ShulkerTech.Core.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    var _currentUser = await UserManager.GetUserAsync(User);
    if (_currentUser?.IsAdmin == true)
    {
        var _host = Context.Request.Host.Host;
        var _firstSegment = _host.Split('.')[0];
        string[] _knownSubdomains = ["wiki", "admin"];
        var _rootHost = _knownSubdomains.Contains(_firstSegment, StringComparer.OrdinalIgnoreCase)
            ? _host[(_firstSegment.Length + 1)..]
            : _host;
        var _port = Context.Request.Host.Port;
        var _adminBase = $"{Context.Request.Scheme}://admin.{_rootHost}{(_port.HasValue ? $":{_port}" : "")}";
        <li class="hidden sm:flex"><a class="nav-link" href="@_adminBase/">ADMIN</a></li>
        <a class="nav-link sm:hidden" href="@_adminBase/">ADMIN</a>
    }

    <!-- Desktop Links -->
    <li class="hidden sm:flex">
        <a asp-area="Identity" asp-page="/Account/Manage/Index"
           class="nav-link" style="color: var(--color-plasma); font-family: var(--font-mono); font-size: 0.7rem; text-decoration: none;"
           onmouseover="this.style.textDecoration='underline';" onmouseout="this.style.textDecoration='none';">
            @User.Identity?.Name
        </a>
    </li>
    <li class="hidden sm:flex">
        <a asp-area="Identity" asp-page="/Account/Logout" class="nav-link">SIGN OUT</a>
    </li>

    <!-- Mobile Links -->
    <a asp-area="Identity" asp-page="/Account/Manage/Index"
       class="nav-link sm:hidden" style="color: var(--color-plasma); font-family: var(--font-mono); font-size: 0.7rem; text-decoration: none;"
       onmouseover="this.style.textDecoration='underline';" onmouseout="this.style.textDecoration='none';">
        @User.Identity?.Name
    </a>
    <a asp-area="Identity" asp-page="/Account/Logout" class="nav-link sm:hidden">SIGN OUT</a>
}
else
{
    <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">ENLIST</a>
    <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">SIGN IN</a>
}
