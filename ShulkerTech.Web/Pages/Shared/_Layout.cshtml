@using Microsoft.AspNetCore.Identity
@using ShulkerTech.Core.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery AntiforgeryService
@{
    // Build subdomain URLs from the current request so this works in any environment
    // (dev: shulker.dev:8080, prod: shulkertech.com) without hardcoding domains.
    var _host = Context.Request.Host.Host;
    var _firstSegment = _host.Split('.')[0];
    string[] _knownSubdomains = ["wiki", "admin"];
    var _rootHost = _knownSubdomains.Contains(_firstSegment, StringComparer.OrdinalIgnoreCase)
        ? _host[(_firstSegment.Length + 1)..]
        : _host;
    var _port = Context.Request.Host.Port;
    var _portSuffix = _port.HasValue ? $":{_port}" : string.Empty;
    var _scheme = Context.Request.Scheme;
    var _base = $"{_scheme}://{_rootHost}{_portSuffix}";
    var _wikiBase = $"{_scheme}://wiki.{_rootHost}{_portSuffix}";
    var _adminBase = $"{_scheme}://admin.{_rootHost}{_portSuffix}";
    var _layoutCurrentUser = SignInManager.IsSignedIn(User) ? await UserManager.GetUserAsync(User) : null;
}
<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Shulker Tech</title>

    <!-- Restore theme before paint to avoid flash of wrong accent color -->
    <!-- Reads cookie first so theme persists across subdomains (cookies are domain-scoped, localStorage is origin-scoped) -->
    <script>(function(){function gc(n){var m=document.cookie.match('(?:^|;)\\s*'+n+'\\s*=\\s*([^;]*)');return m?m[1]:null;}var t=gc('theme')||localStorage.getItem('theme')||'plasma';document.documentElement.dataset.theme=t;})()</script>

    <!-- Google Fonts: sci-fi display + fantasy accent + body -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=VT323&family=Orbitron:wght@400;600;900&family=Exo+2:wght@300;400;600&family=Share+Tech+Mono&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/app.out.css" asp-append-version="true" />

    @{ var _csrfTokens = AntiforgeryService.GetAndStoreTokens(Context); }
    <meta name="csrf-token" content="@_csrfTokens.RequestToken" />

    @await RenderSectionAsync("Head", required: false)
</head>
<body class="min-h-full flex flex-col" style="background-color: var(--color-void); color: var(--color-crystal);">

    <!-- Top navigation -->
    <header style="position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: color-mix(in oklab, var(--color-deep-space) 95%, transparent); border-bottom: 1px solid color-mix(in oklab, var(--color-accent) 20%, transparent); backdrop-filter: blur(2px);">
        <nav class="px-4 sm:px-8 lg:px-16 xl:px-24 2xl:px-32 flex items-center justify-between h-14 sm:h-16">

            <!-- Brand -->
            <a href="@_base/" class="flex items-center gap-2" style="font-family: var(--font-display); color: var(--color-accent); text-shadow: 0 0 12px var(--color-accent); font-size: 1rem; letter-spacing: 0.15em; font-weight: 900; text-decoration: none;">
                <img src="~/images/redstone_dust.webp" alt="redstone dust"
                     width="16" height="16"
                     style="display:inline-block; vertical-align:middle; image-rendering: pixelated; animation: magic-pulse 3s ease-in-out infinite; filter: drop-shadow(0 0 5px #cc1a1a);" />
                SHULKER TECH
            </a>

            <!-- Mobile menu toggle -->
            <button id="nav-toggle" class="sm:hidden p-2" style="color: var(--color-muted);" aria-label="Toggle menu"
                    hx-on:click="document.getElementById('nav-menu').classList.toggle('hidden')">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>

            <!-- Desktop links -->
            <ul class="hidden sm:flex items-center gap-6">
                <li><a class="nav-link" href="@_base/">Home</a></li>
                <li><a class="nav-link" href="@_wikiBase/">Wiki</a></li>
                @if (_layoutCurrentUser?.IsAdmin == true)
                {
                    <li><a class="nav-link" href="@_adminBase/">ADMIN</a></li>
                }
                <partial name="_LoginPartial" />
            </ul>
        </nav>

        <!-- Mobile links -->
        <div id="nav-menu" class="hidden sm:hidden px-4 pb-4 flex flex-col gap-3">
            <a class="nav-link" href="@_base/">Home</a>
            <a class="nav-link" href="@_wikiBase/">Wiki</a>
            @if (_layoutCurrentUser?.IsAdmin == true)
            {
                <a class="nav-link" href="@_adminBase/">ADMIN</a>
            }
            <partial name="_LoginPartial" />
        </div>
    </header>

    <!-- Page content — pt offsets the fixed header (h-14 mobile / h-16 sm+) -->
    <main class="flex-1 pt-14 sm:pt-16">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="mt-auto py-6 px-4" style="border-top: 1px solid color-mix(in oklab, var(--color-accent) 10%, transparent);">
        <div class="px-4 sm:px-8 lg:px-16 xl:px-24 2xl:px-32 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs sm:text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">
            <span>&copy; @DateTime.UtcNow.Year SHULKER TECH — ALL SYSTEMS NOMINAL</span>
            <a asp-page="/Privacy" style="color: var(--color-muted);">Privacy</a>
        </div>
    </footer>

    <!-- Vendored JS — no CDN, no npm -->
    <script src="~/js/htmx.min.js"></script>
    <script src="~/js/signalr.min.js"></script>

    <script>
        // Settings dropdown
        var settingsBtn = document.getElementById('settings-btn');
        var settingsDropdown = document.getElementById('settings-dropdown');
        if (settingsBtn && settingsDropdown) {
            settingsBtn.addEventListener('click', function (e) {
                e.stopPropagation();
                var nowHidden = settingsDropdown.classList.toggle('hidden');
                settingsBtn.setAttribute('aria-expanded', String(!nowHidden));
            });
            document.addEventListener('click', function () {
                settingsDropdown.classList.add('hidden');
                settingsBtn.setAttribute('aria-expanded', 'false');
            });
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') {
                    settingsDropdown.classList.add('hidden');
                    settingsBtn.setAttribute('aria-expanded', 'false');
                }
            });
        }

        // Theme toggle (plasma ↔ arcane accent)
        function updateThemeBtn() {
            var current = document.documentElement.dataset.theme || 'plasma';
            document.querySelectorAll('[data-theme-toggle]').forEach(function (btn) {
                if (current === 'plasma') {
                    btn.textContent = '◈ Arcane Mode';
                    btn.style.color = 'var(--color-arcane)';
                } else {
                    btn.textContent = '◈ Plasma Mode';
                    btn.style.color = 'var(--color-plasma)';
                }
            });
        }

        function toggleTheme() {
            var html = document.documentElement;
            var next = html.dataset.theme === 'plasma' ? 'arcane' : 'plasma';
            html.dataset.theme = next;
            // Write to a cookie scoped to the root domain so all subdomains share the same theme
            document.cookie = 'theme=' + next + '; max-age=' + (365 * 24 * 60 * 60) + '; domain=.@_rootHost; path=/; SameSite=Lax';
            localStorage.setItem('theme', next);
            updateThemeBtn();
        }

        document.querySelectorAll('[data-theme-toggle]').forEach(function (btn) {
            btn.addEventListener('click', toggleTheme);
        });
        updateThemeBtn();

        // Live "checked X ago" timestamps on server cards
        function updateCheckedTimes() {
            var now = Date.now();
            document.querySelectorAll('[data-checked-at]').forEach(function (el) {
                var diffSec = Math.floor((now - parseInt(el.dataset.checkedAt, 10)) / 1000);
                el.textContent = diffSec < 60 ? 'checked just now' : 'checked ' + Math.floor(diffSec / 60) + 'm ago';
            });
        }
        updateCheckedTimes();
        setInterval(updateCheckedTimes, 10000);
        document.addEventListener('htmx:afterSwap', updateCheckedTimes);
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
