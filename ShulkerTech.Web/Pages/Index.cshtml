@page
@model IndexModel
@{
    ViewData["Title"] = "Shulker Tech";
    Layout = "/Pages/Shared/_Layout.cshtml";

    var _host = HttpContext.Request.Host.Host;
    var _firstSegment = _host.Split('.')[0];
    string[] _knownSubdomains = ["wiki", "admin"];
    var _rootHost = _knownSubdomains.Contains(_firstSegment, StringComparer.OrdinalIgnoreCase)
        ? _host[(_firstSegment.Length + 1)..]
        : _host;
    var _port = HttpContext.Request.Host.Port;
    var _portSuffix = _port.HasValue ? $":{_port}" : string.Empty;
    var _wikiBase = $"{HttpContext.Request.Scheme}://wiki.{_rootHost}{_portSuffix}";
}

@section Head {
    <style>
        /* Pull hero section up behind the fixed nav */
        #hero { margin-top: -4rem; }
    </style>
}

@* ── Hero ────────────────────────────────────────────────────────────────── *@
<section id="hero" class="relative w-full scanlines" style="height: 100svh; min-height: 500px;">

    @* Map iframe *@
    @if (Model.MapUrl is not null)
    {
        <iframe src="@Model.MapUrl"
                class="absolute inset-0 w-full h-full"
                style="border: none; pointer-events: none; touch-action: none;"
                loading="lazy"
                title="Shulker Tech world map"
                sandbox="allow-scripts allow-same-origin allow-popups">
        </iframe>
    }
    else
    {
        @* Fallback when no map is configured *@
        <div class="absolute inset-0" style="background: radial-gradient(ellipse at 60% 40%, var(--color-nebula), var(--color-void));"></div>
    }

    @* Top mask — matches the fixed nav height, hides map server UI beneath it *@
    <div style="position: absolute; top: 0; left: 0; right: 0; height: 4rem; pointer-events: none; background: rgb(from var(--color-void) r g b / 0.2); backdrop-filter: blur(16px);"></div>

    @* Dark gradient overlay — pointer-events: none lets the iframe stay interactive *@
    <div class="absolute inset-0 pointer-events-none"
         style="background:
            linear-gradient(to bottom,
                transparent 0%,
                transparent 20%,
                color-mix(in oklab, var(--color-void) 20%, transparent) 35%,
                color-mix(in oklab, var(--color-void) 20%, transparent) 65%,
                color-mix(in oklab, var(--color-void) 85%, transparent) 100%
            );">
    </div>

    @* Hero content *@
    <div class="absolute inset-0 flex flex-col items-center justify-center px-4 text-center pointer-events-none">

        @* Subtle backdrop panel so text stays legible over the map in all themes *@
        <div class="mb-12 pointer-events-none"
             style="background: color-mix(in oklab, var(--color-void) 20%, transparent);
                    backdrop-filter: blur(2px);
                    -webkit-backdrop-filter: blur(2px);
                    border: 1px solid color-mix(in oklab, var(--color-accent) 10%, transparent);
                    border-radius: 0.75rem;
                    padding: 2rem 2.5rem;">

            @* Eyebrow *@
            <p class="mb-5 tracking-widest pointer-events-none"
               style="font-family: var(--font-fantasy); font-size: 1.25rem; color: var(--color-redstone); text-shadow: 0 0 12px var(--color-redstone); text-transform: uppercase; animation: rune-shimmer 4s ease-in-out infinite;">
                ▶ &nbsp; Server Online &nbsp; ◀
            </p>

            @* Title *@
            <h1 class="mb-6 pointer-events-none"
                style="font-size: clamp(2.5rem, 8vw, 6.5rem);
                       font-weight: 700;
                       line-height: 1;
                       color: var(--color-crystal);
                       text-shadow: 0 0 40px color-mix(in oklab, var(--color-accent) 60%, transparent),
                                    0 0 80px color-mix(in oklab, var(--color-arcane) 30%, transparent),
                                    0 0 120px color-mix(in oklab, var(--color-redstone) 15%, transparent);">
                <span style="font-family: var(--font-fantasy); letter-spacing: 0.06em;">SHULKER</span><br>
                <span style="font-family: var(--font-display); letter-spacing: 0.12em; font-weight: 900; color: var(--color-accent);">TECH</span>
            </h1>

            @* Tagline *@
            <p class="mb-0 max-w-lg pointer-events-none"
               style="font-family: var(--font-body); font-size: 1.15rem; font-weight: 300;
                      color: color-mix(in oklab, var(--color-crystal) 80%, transparent);
                      text-shadow: 0 2px 8px var(--color-void);">
                @Model.Site.HeroTagline
            </p>

        </div>

        @* CTAs — pointer-events: auto so they're clickable through the overlay *@
        <div class="flex flex-col sm:flex-row gap-4 pointer-events-auto">
            <a href="@_wikiBase/"
               class="btn-primary px-10 py-3">
                ⛏ EXPLORE THE WIKI
            </a>
            <a href="#about"
               class="px-10 py-3 rounded"
               style="font-family: var(--font-display); font-size: 0.8rem; letter-spacing: 0.12em;
                      text-transform: uppercase; color: var(--color-crystal);
                      border: 1px solid color-mix(in oklab, var(--color-crystal) 30%, transparent);
                      transition: border-color 150ms, color 150ms; text-decoration: none;"
               onmouseover="this.style.borderColor='var(--color-redstone)'; this.style.color='var(--color-redstone)';"
               onmouseout="this.style.borderColor='color-mix(in oklab, var(--color-crystal) 30%, transparent)'; this.style.color='var(--color-crystal)';">
                LEARN MORE
            </a>
        </div>
    </div>

    @* Scroll indicator *@
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 pointer-events-none flex flex-col items-center gap-2"
         style="color: var(--color-muted); opacity: 0.6;">
        <span class="text-xs" style="font-family: var(--font-mono); letter-spacing: 0.1em;">SCROLL</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
    </div>
</section>

@* ── Rune divider ───────────────────────────────────────────────────────── *@
<div class="px-4 sm:px-8 lg:px-16 xl:px-24 2xl:px-32">
    <div class="rune-divider" style="font-family: var(--font-fantasy); font-size: 1.4rem; letter-spacing: 0.3em;">◆ ◆ ◆</div>
</div>

@* ── Server status ──────────────────────────────────────────────────────── *@
<section class="px-4 sm:px-8 lg:px-16 xl:px-24 2xl:px-32 py-16">

    <div class="mb-8">
        <p class="text-xs tracking-widest mb-2" style="font-family: var(--font-mono); color: var(--color-rune); letter-spacing: 0.15em;">&#9670; LIVE STATUS</p>
        <h2 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 900; letter-spacing: 0.1em; color: var(--color-crystal);">
            THE NETWORK
        </h2>
    </div>

    <div id="server-status-cards"
         hx-get="/ServerStatus"
         hx-trigger="load, every 30s"
         hx-swap="innerHTML"
         class="flex flex-col gap-4">
        @* Populated by HTMX *@
        <div class="panel p-5 flex items-center gap-4">
            <div class="w-16 h-16 rounded flex-none" style="background: color-mix(in oklab, var(--color-accent) 6%, transparent); border: 1px solid color-mix(in oklab, var(--color-accent) 15%, transparent); animation: pulse 2s ease-in-out infinite;"></div>
            <div class="flex flex-col gap-2 flex-1">
                <div class="h-4 rounded w-32" style="background: color-mix(in oklab, var(--color-accent) 10%, transparent); animation: pulse 2s ease-in-out infinite;"></div>
                <div class="h-3 rounded w-48" style="background: color-mix(in oklab, var(--color-muted) 15%, transparent); animation: pulse 2s ease-in-out infinite;"></div>
            </div>
        </div>
    </div>
</section>

@* ── Rune divider ───────────────────────────────────────────────────────── *@
<div class="px-4 sm:px-8 lg:px-16 xl:px-24 2xl:px-32">
    <div class="rune-divider" style="font-family: var(--font-fantasy); font-size: 1.4rem; letter-spacing: 0.3em;">◆ ◆ ◆</div>
</div>

@* ── About section ─────────────────────────────────────────────────────── *@
<section id="about" class="px-4 sm:px-8 lg:px-16 xl:px-24 2xl:px-32 py-24 sm:py-32 grid sm:grid-cols-3 gap-10 sm:gap-14">

    <div class="panel panel-redstone p-8 flex flex-col gap-4">
        <span class="magic-glow" style="font-size: 2rem; color: var(--color-redstone);">⛏</span>
        <h3 style="font-family: var(--font-fantasy); color: var(--color-crystal); font-size: 1.2rem; letter-spacing: 0.06em;">@Model.Site.BuildCardTitle</h3>
        <p style="font-size: 1rem; color: var(--color-muted); line-height: 1.7;">
            @Model.Site.BuildCardBody
        </p>
    </div>

    <div class="panel p-8 flex flex-col gap-4">
        <span class="magic-glow" style="font-size: 2rem; color: var(--color-accent);">◈</span>
        <h3 style="font-family: var(--font-fantasy); color: var(--color-crystal); font-size: 1.2rem; letter-spacing: 0.06em;">@Model.Site.ExploreCardTitle</h3>
        <p style="font-size: 1rem; color: var(--color-muted); line-height: 1.7;">
            @Model.Site.ExploreCardBody
        </p>
    </div>

    <div class="panel panel-arcane p-8 flex flex-col gap-4">
        <span class="magic-glow" style="font-size: 2rem; color: var(--color-arcane);">⚡</span>
        <h3 style="font-family: var(--font-fantasy); color: var(--color-crystal); font-size: 1.2rem; letter-spacing: 0.06em;">@Model.Site.ConnectCardTitle</h3>
        <p style="font-size: 1rem; color: var(--color-muted); line-height: 1.7;">
            @Model.Site.ConnectCardBody
        </p>
    </div>

</section>

