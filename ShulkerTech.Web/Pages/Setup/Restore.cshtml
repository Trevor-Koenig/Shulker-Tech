@page "/setup/restore"
@model RestoreModel
@{
    ViewData["Title"] = "Restore Database";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="min-h-screen flex items-center justify-center px-4 py-16"
     style="background: radial-gradient(ellipse at 50% 0%, color-mix(in oklab, var(--color-nebula) 80%, transparent), var(--color-void) 70%);">

    <div class="w-full max-w-md">

        <div class="text-center mb-8">
            <p class="text-xs tracking-widest mb-3" style="font-family: var(--font-mono); color: var(--color-rune);">&#9670; FIRST RUN &#9670;</p>
            <h1 style="font-family: var(--font-display); font-size: 1.75rem; font-weight: 900; letter-spacing: 0.1em; color: var(--color-crystal);">
                RESTORE DATABASE
            </h1>
            <p class="mt-3 text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">
                Restore a previous backup to recover your data.
            </p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="mb-5 text-xs p-3 rounded"
                 style="color: var(--color-rune); background: color-mix(in oklab, var(--color-rune) 10%, transparent);
                        border: 1px solid color-mix(in oklab, var(--color-rune) 30%, transparent); font-family: var(--font-mono);">
                @Model.ErrorMessage
            </div>
        }

        <!-- ── Upload a backup file ──────────────────────────────────────── -->
        <div class="panel p-6 flex flex-col gap-4 mb-5"
             style="border-color: color-mix(in oklab, var(--color-accent) 35%, transparent);">

            <div>
                <p class="text-xs tracking-widest mb-1" style="font-family: var(--font-mono); color: var(--color-accent);">&#9670; UPLOAD BACKUP FILE</p>
                <p class="text-xs" style="color: var(--color-muted); font-family: var(--font-mono); line-height: 1.6;">
                    Upload a <code>.sql.gz</code> backup from your local machine.
                </p>
            </div>

            <form method="post" action="/setup/restore?handler=Upload" enctype="multipart/form-data"
                  class="flex flex-col gap-3"
                  data-confirm="This will overwrite the current database with the uploaded backup. This cannot be undone. Continue?">
                @Html.AntiForgeryToken()

                <div class="flex flex-col gap-1">
                    <label class="text-xs tracking-wider" style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">BACKUP FILE</label>
                    <input name="uploadedBackup" type="file" accept=".sql.gz,.gz"
                           class="w-full px-3 py-2 rounded text-xs"
                           style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent);
                                  color: var(--color-crystal); outline: none; font-family: var(--font-mono);" />
                </div>

                <div class="flex flex-col gap-1">
                    <label class="text-xs tracking-wider" style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">SETUP CODE</label>
                    <input name="setupCode" type="password" autocomplete="off"
                           placeholder="Enter the setup code"
                           class="w-full px-3 py-2 rounded text-sm"
                           style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent);
                                  color: var(--color-crystal); outline: none; font-family: var(--font-mono);" />
                </div>

                <button type="submit" class="btn-nav w-full py-2 text-xs"
                        style="border-color: var(--color-accent); color: var(--color-accent);">
                    RESTORE FROM UPLOAD
                </button>
            </form>
        </div>

        <!-- ── Restore from existing on-disk backup ─────────────────────── -->
        @if (Model.AvailableBackups.Count > 0)
        {
            <div class="flex items-center gap-3 mb-5">
                <div class="flex-1 h-px" style="background: color-mix(in oklab, var(--color-arcane) 20%, transparent);"></div>
                <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted);">OR FROM DISK</span>
                <div class="flex-1 h-px" style="background: color-mix(in oklab, var(--color-arcane) 20%, transparent);"></div>
            </div>

            <div class="panel p-6 flex flex-col gap-4 mb-5"
                 style="border-color: color-mix(in oklab, var(--color-accent) 35%, transparent);">

                <div>
                    <p class="text-xs tracking-widest mb-1" style="font-family: var(--font-mono); color: var(--color-accent);">&#9670; EXISTING BACKUPS</p>
                    <p class="text-xs" style="color: var(--color-muted); font-family: var(--font-mono); line-height: 1.6;">
                        @Model.AvailableBackups.Count backup@(Model.AvailableBackups.Count == 1 ? "" : "s") found on disk.
                    </p>
                </div>

                <form method="post" action="/setup/restore?handler=Existing" class="flex flex-col gap-3"
                      data-confirm="This will overwrite the current database with the selected backup. This cannot be undone. Continue?">
                    @Html.AntiForgeryToken()

                    <div class="flex flex-col gap-1">
                        <label class="text-xs tracking-wider" style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">BACKUP FILE</label>
                        <select name="backupFile"
                                class="w-full px-3 py-2 rounded text-xs"
                                style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent);
                                       color: var(--color-crystal); outline: none; font-family: var(--font-mono);">
                            @foreach (var backup in Model.AvailableBackups)
                            {
                                <option value="@backup.FileName">@backup.DisplayName</option>
                            }
                        </select>
                    </div>

                    <div class="flex flex-col gap-1">
                        <label class="text-xs tracking-wider" style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">SETUP CODE</label>
                        <input name="setupCode" type="password" autocomplete="off"
                               placeholder="Enter the setup code"
                               class="w-full px-3 py-2 rounded text-sm"
                               style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent);
                                      color: var(--color-crystal); outline: none; font-family: var(--font-mono);" />
                    </div>

                    <button type="submit" class="btn-nav w-full py-2 text-xs"
                            style="border-color: var(--color-accent); color: var(--color-accent);">
                        RESTORE FROM DISK
                    </button>
                </form>
            </div>
        }

        <div class="text-center">
            <a href="/setup" style="font-family: var(--font-mono); font-size: 0.72rem; color: var(--color-muted); text-decoration: none; letter-spacing: 0.06em;">
                ← BACK TO SETUP
            </a>
        </div>

    </div>
</div>
