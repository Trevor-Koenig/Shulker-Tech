@page "/setup"
@model IndexModel
@{
    ViewData["Title"] = "Setup";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="min-h-screen flex items-center justify-center px-4 py-16"
     style="background: radial-gradient(ellipse at 50% 0%, color-mix(in oklab, var(--color-nebula) 80%, transparent), var(--color-void) 70%);">

    <div class="w-full max-w-sm">

        <div class="text-center mb-8">
            <p class="text-xs tracking-widest mb-3" style="font-family: var(--font-mono); color: var(--color-rune);">&#9670; FIRST RUN &#9670;</p>
            <h1 style="font-family: var(--font-display); font-size: 1.75rem; font-weight: 900; letter-spacing: 0.1em; color: var(--color-crystal);">
                SYSTEM SETUP
            </h1>
            <p class="mt-3 text-sm" style="color: var(--color-muted); font-family: var(--font-mono);">
                Create the administrator account to initialise Shulker Tech.
            </p>
        </div>

        @if (Model.AvailableBackups.Count > 0)
        {
            <div class="panel p-6 flex flex-col gap-4 mb-6"
                 style="border-color: color-mix(in oklab, var(--color-accent) 35%, transparent);">
                <div>
                    <p class="text-xs tracking-widest mb-1" style="font-family: var(--font-mono); color: var(--color-accent);">&#9670; RESTORE FROM BACKUP</p>
                    <p class="text-xs" style="color: var(--color-muted); font-family: var(--font-mono); line-height: 1.6;">
                        @Model.AvailableBackups.Count backup@(Model.AvailableBackups.Count == 1 ? "" : "s") found. Restore one to skip account creation and recover your previous data.
                    </p>
                </div>

                @if (!string.IsNullOrEmpty(Model.RestoreErrorMessage))
                {
                    <div class="text-xs p-3 rounded" style="color: var(--color-rune); background: color-mix(in oklab, var(--color-rune) 10%, transparent); border: 1px solid color-mix(in oklab, var(--color-rune) 30%, transparent); font-family: var(--font-mono);">
                        @Model.RestoreErrorMessage
                    </div>
                }

                <form method="post" action="/setup?handler=Restore" class="flex flex-col gap-3"
                      data-confirm="This will overwrite the current database with the selected backup. This cannot be undone. Continue?">
                    @Html.AntiForgeryToken()

                    <div class="flex flex-col gap-1">
                        <label class="text-xs tracking-wider" style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">BACKUP FILE</label>
                        <select name="backupFile"
                                class="w-full px-3 py-2 rounded text-xs"
                                style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent); color: var(--color-crystal); outline: none; font-family: var(--font-mono);">
                            @foreach (var backup in Model.AvailableBackups)
                            {
                                <option value="@backup.FileName">@backup.DisplayName</option>
                            }
                        </select>
                    </div>

                    <div class="flex flex-col gap-1">
                        <label class="text-xs tracking-wider" style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">SETUP CODE</label>
                        <input name="setupCode" type="password" autocomplete="off"
                               placeholder="Enter the setup code"
                               class="w-full px-3 py-2 rounded text-sm"
                               style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent); color: var(--color-crystal); outline: none; font-family: var(--font-mono);" />
                    </div>

                    <button type="submit" class="btn-nav w-full py-2 text-xs"
                            style="border-color: var(--color-accent); color: var(--color-accent);">
                        RESTORE DATABASE
                    </button>

                </form>
            </div>

            <div class="flex items-center gap-3 mb-6">
                <div class="flex-1 h-px" style="background: color-mix(in oklab, var(--color-arcane) 20%, transparent);"></div>
                <span class="text-xs" style="font-family: var(--font-mono); color: var(--color-muted);">OR CREATE NEW</span>
                <div class="flex-1 h-px" style="background: color-mix(in oklab, var(--color-arcane) 20%, transparent);"></div>
            </div>
        }

        <div class="panel panel-arcane p-8 flex flex-col gap-5">

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="text-xs p-3 rounded" style="color: var(--color-rune); background: color-mix(in oklab, var(--color-rune) 10%, transparent); border: 1px solid color-mix(in oklab, var(--color-rune) 30%, transparent); font-family: var(--font-mono);">
                    @Model.ErrorMessage
                </div>
            }

            <form method="post" class="flex flex-col gap-4">

                @* Setup code *@
                <div class="flex flex-col gap-1">
                    <label asp-for="Input.SetupCode" class="text-xs tracking-wider"
                           style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">SETUP CODE</label>
                    <input asp-for="Input.SetupCode" type="password" autocomplete="off" aria-required="true"
                           placeholder="Enter the setup code"
                           class="w-full px-3 py-2 rounded text-sm"
                           style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-rune) 40%, transparent); color: var(--color-crystal); outline: none;"
                           onfocus="this.style.borderColor='var(--color-rune)'; this.style.boxShadow='0 0 8px color-mix(in oklab, var(--color-rune) 30%, transparent)';"
                           onblur="this.style.borderColor='color-mix(in oklab, var(--color-rune) 40%, transparent)'; this.style.boxShadow='none';" />
                    <span asp-validation-for="Input.SetupCode" class="text-xs" style="color: var(--color-rune); font-family: var(--font-mono);"></span>
                </div>

                <div class="h-px" style="background: color-mix(in oklab, var(--color-arcane) 20%, transparent);"></div>

                @* Email *@
                <div class="flex flex-col gap-1">
                    <label asp-for="Input.Email" class="text-xs tracking-wider"
                           style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">EMAIL</label>
                    <input asp-for="Input.Email" type="email" autocomplete="username" aria-required="true"
                           placeholder="admin@example.com"
                           class="w-full px-3 py-2 rounded text-sm"
                           style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent); color: var(--color-crystal); outline: none;"
                           onfocus="this.style.borderColor='var(--color-accent)'; this.style.boxShadow='0 0 8px color-mix(in oklab, var(--color-accent) 30%, transparent)';"
                           onblur="this.style.borderColor='color-mix(in oklab, var(--color-accent) 30%, transparent)'; this.style.boxShadow='none';" />
                    <span asp-validation-for="Input.Email" class="text-xs" style="color: var(--color-rune); font-family: var(--font-mono);"></span>
                </div>

                @* Password *@
                <div class="flex flex-col gap-1">
                    <label asp-for="Input.Password" class="text-xs tracking-wider"
                           style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">PASSWORD</label>
                    <input asp-for="Input.Password" type="password" autocomplete="new-password" aria-required="true"
                           placeholder="••••••••"
                           class="w-full px-3 py-2 rounded text-sm"
                           style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent); color: var(--color-crystal); outline: none;"
                           onfocus="this.style.borderColor='var(--color-accent)'; this.style.boxShadow='0 0 8px color-mix(in oklab, var(--color-accent) 30%, transparent)';"
                           onblur="this.style.borderColor='color-mix(in oklab, var(--color-accent) 30%, transparent)'; this.style.boxShadow='none';" />
                    <span asp-validation-for="Input.Password" class="text-xs" style="color: var(--color-rune); font-family: var(--font-mono);"></span>
                </div>

                @* Confirm password *@
                <div class="flex flex-col gap-1">
                    <label asp-for="Input.ConfirmPassword" class="text-xs tracking-wider"
                           style="font-family: var(--font-display); color: var(--color-muted); letter-spacing: 0.08em;">CONFIRM PASSWORD</label>
                    <input asp-for="Input.ConfirmPassword" type="password" autocomplete="new-password" aria-required="true"
                           placeholder="••••••••"
                           class="w-full px-3 py-2 rounded text-sm"
                           style="background: var(--color-void); border: 1px solid color-mix(in oklab, var(--color-accent) 30%, transparent); color: var(--color-crystal); outline: none;"
                           onfocus="this.style.borderColor='var(--color-accent)'; this.style.boxShadow='0 0 8px color-mix(in oklab, var(--color-accent) 30%, transparent)';"
                           onblur="this.style.borderColor='color-mix(in oklab, var(--color-accent) 30%, transparent)'; this.style.boxShadow='none';" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-xs" style="color: var(--color-rune); font-family: var(--font-mono);"></span>
                </div>

                <button type="submit" class="btn-primary w-full py-3 mt-1"
                        style="background: linear-gradient(135deg, var(--color-rune), var(--color-arcane));">
                    INITIALISE SYSTEM
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
